@import '../common/index.wxss';
.van-dialog {
  background-color: var(--van-dialog-background, var(--bg-card, #1E1E1E)) !important;
  border-radius: 24rpx !important;
  font-size: var(--dialog-font-size, 16px);
  overflow: hidden;
  top: 45% !important;
  width: var(--dialog-width, 320px);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3) !important;
  border: 1rpx solid var(--van-border-color, var(--border-color, #333333)) !important;
  color: var(--van-dialog-text-color, var(--text-primary, #F5F5F5)) !important;
}

@media (max-width: 321px) {
  .van-dialog {
    width: var(--dialog-small-screen-width, 90%);
  }
}

.van-dialog__header {
  font-weight: 600;
  line-height: 24px;
  padding-top: 32rpx !important;
  padding-bottom: 16rpx !important;
  text-align: center;
  color: var(--van-dialog-text-color, var(--text-primary, #F5F5F5)) !important;
  font-size: 34rpx !important;
}

.van-dialog__header--isolated {
  padding: var(--dialog-header-isolated-padding, 24px 0);
}

.van-dialog__message {
  -webkit-overflow-scrolling: touch;
  font-size: var(--dialog-message-font-size, 14px);
  line-height: var(--dialog-message-line-height, 20px);
  max-height: var(--dialog-message-max-height, 60vh);
  overflow-y: auto;
  padding: 0 32rpx 24rpx !important;
  text-align: center;
  color: var(--van-text-color-2, var(--text-secondary, #A0A0A0)) !important;
}

.van-dialog__message-text {
  word-wrap: break-word;
}

.van-dialog__message--hasTitle {
  color: var(--text-secondary, #A0A0A0) !important;
  padding-top: var(--dialog-has-title-message-padding-top, 8px);
}

.van-dialog__footer {
  display: flex;
  border-top: 1rpx solid var(--divider, #2A2A2A) !important;
  background: var(--bg-card, #1E1E1E) !important;
}

.van-dialog__footer--round-button {
  padding: 16rpx 24rpx 24rpx !important;
  position: relative !important;
  gap: 16rpx !important;
}

.van-dialog__button {
  flex: 1;
  height: 80rpx !important;
  border-radius: 16rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
}

.van-dialog__cancel {
  background: var(--bg-card-secondary, #252525) !important;
  color: var(--text-secondary, #A0A0A0) !important;
  border: 1rpx solid var(--border-color, #333333) !important;
  border-radius: 16rpx !important;
}

.van-dialog__confirm {
  background: var(--color-primary, #22C55E) !important;
  color: #FFFFFF !important;
  font-weight: 600 !important;
  border-radius: 16rpx !important;
}

.van-dialog__confirm:active {
  background: var(--color-primary-dark, #16A34A) !important;
}

/* 确保 slot 内的 van-field 样式正确 */
.van-dialog .van-cell {
  background: transparent !important;
  border-bottom: 1rpx solid var(--divider, #2A2A2A) !important;
}

.van-dialog .van-field__label {
  color: var(--text-secondary, #A0A0A0) !important;
  font-size: 28rpx !important;
}

.van-dialog .van-field__control {
  color: var(--text-primary, #F5F5F5) !important;
  font-size: 32rpx !important;
}

.van-dialog .van-field__placeholder {
  color: var(--text-placeholder, #555555) !important;
}

/* 弹窗内部表单样式 */
.van-dialog .dialog-form {
  padding: 16rpx 0;
}

.van-dialog .dialog-form-item {
  padding: 16rpx 32rpx;
}

.van-dialog .dialog-label {
  color: var(--text-secondary, #A0A0A0) !important;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  display: block;
}

.van-dialog-bounce-enter {
  opacity: 0;
  transform: translate3d(-50%, -50%, 0) scale(.7);
}

.van-dialog-bounce-leave-active {
  opacity: 0;
  transform: translate3d(-50%, -50%, 0) scale(.9);
}

/* 浅色主题适配 - 通过page类名 */
page.theme-light .van-dialog {
  background-color: #FFFFFF !important;
  border: 1rpx solid #E5E7EB !important;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15) !important;
}

page.theme-light .van-dialog__header {
  color: #1F2937 !important;
}

page.theme-light .van-dialog__message {
  color: #6B7280 !important;
}

page.theme-light .van-dialog__footer {
  background: #FFFFFF !important;
  border-top-color: #F3F4F6 !important;
}

page.theme-light .van-dialog__cancel {
  background: #F5F5F5 !important;
  color: #6B7280 !important;
  border-color: #E5E7EB !important;
  border-radius: 16rpx !important;
}

page.theme-light .van-dialog__confirm {
  background: #22C55E !important;
  color: #FFFFFF !important;
  font-weight: 600 !important;
  border-radius: 16rpx !important;
}

page.theme-light .van-dialog__confirm:active {
  background: #16A34A !important;
}


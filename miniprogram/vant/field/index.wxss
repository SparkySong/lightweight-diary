@import '../common/index.wxss';
.van-field {
  --cell-icon-size: var(--field-icon-size, 16px);
}

.van-field__label {
  color: var(--text-secondary, #A0A0A0) !important;
}

.van-field__label--disabled {
  color: var(--text-tertiary, #6B6B6B) !important;
}

.van-field__body {
  align-items: center;
  display: flex;
}

.van-field__body--textarea {
  box-sizing: border-box;
  line-height: 1.2em;
  min-height: var(--cell-line-height, 24px);
  padding: 3.6px 0;
}

.van-field__control:empty + .van-field__control {
  display: block;
}

.van-field__control {
  background-color: initial;
  border: 0;
  box-sizing: border-box;
  color: var(--text-primary, #F5F5F5) !important;
  display: none;
  height: var(--cell-line-height, 24px);
  line-height: inherit;
  margin: 0;
  min-height: var(--cell-line-height, 24px);
  padding: 0;
  position: relative;
  resize: none;
  text-align: left;
  width: 100%;
}

.van-field__control:empty {
  display: none;
}

.van-field__control--textarea {
  height: var(--field-text-area-min-height, 18px);
  min-height: var(--field-text-area-min-height, 18px);
}

.van-field__control--error {
  color: var(--color-error, #EF4444) !important;
}

.van-field__control--disabled {
  background-color: initial;
  color: var(--text-tertiary, #6B6B6B) !important;
  opacity: 1;
}

.van-field__control--center {
  text-align: center;
}

.van-field__control--right {
  text-align: right;
}

.van-field__control--custom {
  align-items: center;
  display: flex;
  min-height: var(--cell-line-height, 24px);
}

.van-field__placeholder {
  color: var(--text-placeholder, #555555) !important;
  left: 0;
  pointer-events: none;
  position: absolute;
  right: 0;
  top: 0;
}

.van-field__placeholder--error {
  color: var(--color-error, #EF4444) !important;
}

.van-field__icon-root {
  align-items: center;
  display: flex;
  min-height: var(--cell-line-height, 24px);
}

.van-field__clear-root,
.van-field__icon-container {
  line-height: inherit;
  margin-right: calc(var(--padding-xs, 8px) * -1);
  padding: 0 var(--padding-xs, 8px);
  vertical-align: middle;
}

.van-field__button,
.van-field__clear-root,
.van-field__icon-container {
  flex-shrink: 0;
}

.van-field__clear-root {
  color: var(--text-tertiary, #6B6B6B) !important;
  font-size: var(--field-clear-icon-size, 16px);
}

.van-field__icon-container {
  color: var(--text-tertiary, #6B6B6B) !important;
  font-size: var(--field-icon-size, 16px);
  padding: 0 var(--padding-xs, 8px);
}

.van-field__icon-container:empty {
  display: none;
}

.van-field__icon--error,
.van-field__icon--warning {
  color: var(--field-error-message-color, #ee0a24);
}

.van-field__button {
  padding-left: var(--padding-xs, 8px);
}

.van-field__button:empty {
  display: none;
}

.van-field__error-message {
  color: var(--field-error-message-color, #ee0a24);
  font-size: var(--field-error-message-text-color, 12px);
  text-align: left;
}

.van-field__word-limit {
  color: var(--field-word-limit-color, #646566);
  font-size: var(--field-word-limit-font-size, 12px);
}

/* 浅色主题适配 - 通过page类名 */
page.theme-light .van-field__label {
  color: var(--text-secondary, #6B7280) !important;
}

page.theme-light .van-field__control {
  color: var(--text-primary, #1F2937) !important;
}

page.theme-light .van-field__placeholder {
  color: var(--text-placeholder, #D1D5DB) !important;
}

page.theme-light .van-field__clear-root,
page.theme-light .van-field__icon-container {
  color: var(--text-tertiary, #9CA3AF) !important;
}

/* 浅色主题适配 - 通过Vant theme属性 */
.van-field--light .van-field__label {
  color: var(--text-secondary, #6B7280) !important;
}

.van-field--light .van-field__control {
  color: var(--text-primary, #1F2937) !important;
}

.van-field--light .van-field__placeholder {
  color: var(--text-placeholder, #D1D5DB) !important;
}

.van-field--light .van-field__clear-root,
.van-field--light .van-field__icon-container {
  color: var(--text-tertiary, #9CA3AF) !important;
}

.van-field__word-limit {
  line-height: var(--field-word-limit-line-height, 16px);
  margin-top: var(--padding-base, 4px);
  text-align: right;
}

.van-field__word-num {
  color: var(--field-word-num-color, #ee0a24);
}

.van-field__body--textarea .van-field__word-limit {
  margin-bottom: var(--padding-base, 4px);
  margin-top: 0;
}

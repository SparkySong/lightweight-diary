<!--pages/exercise/exercise.wxml-->
<page-meta
  background-text-style="{{currentTheme === 'light' ? 'dark' : 'light'}}"
  background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  background-color-top="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  background-color-bottom="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  root-background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  navigation-bar-style="{{currentTheme === 'light' ? 'dark' : 'light'}}"
/>
<page class="{{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}">

<view class="theme-bg-fixed {{currentTheme === 'light' ? 'theme-light' : ''}}"></view>
<view class="custom-nav-area"></view>

<view class="container">
  <!-- 今日热量收支看板 -->
  <view class="mint-card balance-card">
    <view class="card-header">
      <text class="card-title mint-text-primary">今日热量收支</text>
    </view>
    <view class="balance-row">
      <view class="balance-item">
        <text class="balance-label mint-text-secondary">摄入</text>
        <text class="balance-value intake">{{todayIntake || 0}}</text>
        <text class="balance-unit mint-text-tertiary">kcal</text>
      </view>
      <view class="balance-divider">
        <view class="balance-diff {{todayBalance <= 0 ? 'surplus-minus' : 'surplus-plus'}}">
          <text class="balance-diff-label">{{todayBalance <= 0 ? '赤字' : '盈余'}}</text>
          <text class="balance-diff-val">{{todayBalanceAbs || 0}}</text>
        </view>
      </view>
      <view class="balance-item">
        <text class="balance-label mint-text-secondary">消耗</text>
        <text class="balance-value burn">{{todayTotalBurn || 0}}</text>
        <text class="balance-unit mint-text-tertiary">kcal</text>
      </view>
    </view>
    <view class="balance-detail">
      <text class="mint-text-tertiary">基础代谢 {{bmr || 0}} + 运动 {{todayBurn || 0}} kcal</text>
    </view>
  </view>

  <!-- 微信步数卡片 -->
  <view class="mint-card step-card mint-mt-md">
    <view class="card-header">
      <text class="card-title mint-text-primary">今日步数</text>
      <view class="step-refresh" bindtap="onRefreshSteps">
        <van-icon name="replay" color="var(--text-tertiary)" size="32rpx" />
        <text class="mint-text-tertiary">{{stepSyncing ? '同步中' : (stepSyncTime || '刷新')}}</text>
      </view>
    </view>
    <view class="step-content">
      <view class="step-main">
        <text class="step-count mint-text-primary">{{todaySteps}}</text>
        <text class="step-unit mint-text-tertiary">步</text>
      </view>
      <view class="step-cal">
        <text class="step-cal-value mint-text-accent">{{stepCalories}}</text>
        <text class="step-cal-unit mint-text-tertiary">kcal</text>
      </view>
    </view>
    <view class="step-hint" wx:if="{{!stepSynced && !stepSyncing}}">
      <text class="mint-text-tertiary">授权微信运动后可自动同步步数</text>
    </view>
  </view>

  <!-- 运动记录列表 -->
  <view class="mint-card record-card mint-mt-md">
    <view class="card-header">
      <text class="card-title mint-text-primary">运动记录</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && exercises.length === 0}}">
      <van-empty description="还没有运动记录" image="search">
        <van-button round type="primary" size="small" bindtap="onAddExercise">开始记录</van-button>
      </van-empty>
    </view>

    <!-- 分组列表 -->
    <view class="exercise-groups" wx:if="{{exercises.length > 0}}">
      <view class="exercise-group" wx:for="{{groupedExercises}}" wx:key="date">
        <view class="group-header">
          <text class="group-date mint-text-primary">{{item.date}}</text>
          <text class="group-cal mint-text-accent">共消耗 {{item.totalCal}} kcal</text>
        </view>
        <view class="exercise-item" wx:for="{{item.items}}" wx:for-item="ex" wx:key="_id">
          <view class="ex-left">
            <text class="ex-icon">{{ex.type === 'walking' ? '🚶' : ex.type === 'running' ? '🏃' : ex.type === 'swimming' ? '🏊' : ex.type === 'gym' ? '💪' : ex.type === 'cycling' ? '🚴' : ex.type === 'yoga' ? '🧘' : '⚡'}}</text>
            <view class="ex-info">
              <text class="ex-name mint-text-primary">{{ex.typeLabel}} {{ex.isAuto ? '(自动)' : ''}}</text>
              <text class="ex-detail mint-text-tertiary">{{ex.duration}}分钟 · {{ex.calories}}kcal{{ex.steps ? ' · ' + ex.steps + '步' : ''}}</text>
            </view>
          </view>
          <van-icon
            wx:if="{{!ex.isAuto}}"
            name="delete"
            color="var(--color-error)"
            size="36rpx"
            catchtap="onDeleteExercise"
            data-id="{{ex._id}}"
          />
        </view>
      </view>
    </view>
  </view>

  <view class="footer-space"></view>
</view>

<!-- 浮动添加按钮 -->
<view class="fab-add" bindtap="onAddExercise">
  <van-icon name="plus" color="#FFFFFF" size="48rpx" />
</view>

<!-- 添加运动弹窗 - Vant Dialog -->
<van-dialog
  show="{{showAddPopup}}"
  title="添加运动"
  show-cancel-button
  use-slot
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  bind:confirm="onSaveExercise"
  bind:cancel="onClosePopup"
  bind:close="onClosePopup"
>
  <view class="dialog-form">
    <!-- 运动类型选择 -->
    <view class="dialog-section">
      <text class="dialog-label mint-text-secondary">运动类型</text>
      <view class="type-grid">
        <van-tag
          wx:for="{{exerciseTypes}}"
          wx:key="type"
          size="large"
          type="{{selectedType === item.type ? 'primary' : 'default'}}"
          data-type="{{item.type}}"
          bindtap="onSelectType"
        >{{item.icon}} {{item.label}}</van-tag>
      </view>
    </view>
    <!-- 运动时长 -->
    <van-field
      type="digit"
      label="时长(分钟)"
      value="{{inputDuration}}"
      bind:input="onDurationInput"
      placeholder="如 30"
    />
    <!-- 消耗卡路里 -->
    <van-field
      type="digit"
      label="卡路里(kcal)"
      value="{{inputCalories}}"
      bind:input="onCaloriesInput"
      placeholder="自动估算，可手动修改"
    />
  </view>
</van-dialog>

<van-toast id="van-toast" />
</page>

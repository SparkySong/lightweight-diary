/* pages/exercise/exercise.wxss */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

page {
  min-height: 100vh;
}

.container {
  padding: 0 30rpx 120rpx;
  padding-top: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: rgba(30, 30, 30, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.title-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
}

/* 热量收支看板 */
.icon-fire {
  color: #F59E0B;
}

.icon-fire::before {
  content: '🔥';
  font-size: 24rpx;
}

.balance-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.balance-item {
  flex: 1;
  text-align: center;
}

.balance-label {
  font-size: 24rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 8rpx;
}

.balance-value {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  line-height: 1.2;
}

.balance-value.intake {
  color: #D4A574;
}

.balance-value.burn {
  color: #5FA895;
}

.balance-unit {
  font-size: 22rpx;
  color: #6B7280;
  display: block;
  margin-top: 4rpx;
}

.balance-divider {
  padding: 0 16rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.balance-diff {
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.2;
}

.balance-diff-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-bottom: 4rpx;
}

.balance-diff-val {
  font-size: 36rpx;
  font-weight: 700;
}

.balance-diff.surplus-minus {
  color: #5FA895;
  background: rgba(95, 168, 149, 0.15);
}

.balance-diff.surplus-plus {
  color: #D4A574;
  background: rgba(212, 165, 116, 0.15);
}

.balance-detail {
  text-align: center;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.balance-detail-text {
  font-size: 22rpx;
  color: #6B7280;
}

/* 步数卡片 */
.icon-step {
  color: #5FA895;
}

.icon-step::before {
  content: '👟';
  font-size: 24rpx;
}

.step-refresh {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #5FA895;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(95, 168, 149, 0.1);
}

.step-refresh.syncing {
  opacity: 0.6;
}

.refresh-icon {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  border-right-color: transparent;
}

.syncing .refresh-icon {
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.step-content {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 8rpx 0;
}

.step-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.step-count {
  font-size: 56rpx;
  font-weight: 700;
  color: #F5F5F5;
}

.step-unit {
  font-size: 26rpx;
  color: #6B7280;
}

.step-cal {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.step-cal-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #5FA895;
}

.step-cal-unit {
  font-size: 22rpx;
  color: #6B7280;
}

.step-hint {
  font-size: 22rpx;
  color: #6B7280;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

/* 运动记录 */
.icon-sport {
  color: #5FA895;
}

.icon-sport::before {
  content: '⚡';
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon-big {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
}

.empty-hint {
  font-size: 24rpx;
  color: #4B5563;
}

/* 分组列表 */
.exercise-group {
  margin-bottom: 16rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 8rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.group-date {
  font-size: 26rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.group-cal {
  font-size: 22rpx;
  color: #5FA895;
}

.exercise-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.exercise-item:last-child {
  border-bottom: none;
}

.ex-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.ex-icon {
  font-size: 36rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.ex-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ex-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #F5F5F5;
}

.ex-detail {
  font-size: 22rpx;
  color: #6B7280;
}

.ex-delete {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.ex-delete:active {
  background: rgba(201, 139, 139, 0.15);
}

.icon-close-small {
  width: 16rpx;
  height: 16rpx;
  position: relative;
}

.icon-close-small::before,
.icon-close-small::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 2rpx;
  background: #6B7280;
  border-radius: 1rpx;
}

.icon-close-small::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-close-small::after { transform: translate(-50%, -50%) rotate(-45deg); }

.ex-delete:active .icon-close-small::before,
.ex-delete:active .icon-close-small::after {
  background: #C98B8B;
}

.footer-space {
  height: 40rpx;
}

/* 浮动添加按钮 */
.fab-add {
  position: fixed;
  right: 40rpx;
  bottom: calc(env(safe-area-inset-bottom) + 60rpx);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5FA895, #4A8C7A);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(95, 168, 149, 0.4);
  z-index: 100;
  transition: transform 0.2s;
}

.fab-add:active {
  transform: scale(0.9);
}

.fab-plus {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.fab-plus::before,
.fab-plus::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  background: #FFFFFF;
  border-radius: 2rpx;
}

.fab-plus::before {
  width: 40rpx;
  height: 4rpx;
  transform: translate(-50%, -50%);
}

.fab-plus::after {
  width: 4rpx;
  height: 40rpx;
  transform: translate(-50%, -50%);
}

/* 弹窗 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.popup-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.add-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1E1E1E;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 30rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  max-height: 80vh;
  overflow-y: auto;
}

.add-popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.popup-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.popup-close:active {
  background: rgba(255, 255, 255, 0.08);
}

.icon-close {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.icon-close::before,
.icon-close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 2rpx;
  background: #9CA3AF;
  border-radius: 1rpx;
}

.icon-close::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-close::after { transform: translate(-50%, -50%) rotate(-45deg); }

.popup-body {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #F5F5F5;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #6B7280;
}

/* 运动类型网格 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.type-item {
  width: calc(25% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: #2D2D2D;
  border: 2rpx solid #3D3D3D;
  border-radius: 16rpx;
  transition: all 0.2s;
  box-sizing: border-box;
}

.type-item.active {
  background: rgba(95, 168, 149, 0.12);
  border-color: #5FA895;
}

.type-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 22rpx;
  color: #F5F5F5;
  font-weight: 500;
}

.popup-footer {
  display: flex;
  gap: 20rpx;
}

.popup-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
  margin: 0;
  font-weight: 500;
  transition: all 0.2s;
}

.popup-btn::after {
  border: none;
}

.popup-btn:active {
  opacity: 0.85;
}

.popup-btn-cancel {
  background: #3D3D3D;
  color: #9CA3AF;
}

.popup-btn-confirm {
  background: #5FA895;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(95, 168, 149, 0.25);
}

/* Toast */
.toast {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 100rpx);
  left: 50%;
  transform: translateX(-50%) translateY(-200rpx);
  background: #1E1E1E;
  border: 1rpx solid rgba(95, 168, 149, 0.3);
  color: #5FA895;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 10000;
  transition: transform 0.3s ease;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.toast.show {
  transform: translateX(-50%) translateY(0);
}

/* ========== 浅色主题适配 ========== */

.theme-light .nav-back {
  background: rgba(0, 0, 0, 0.06);
}

.theme-light .back-arrow {
  border-color: #1F2937;
}

.theme-light .nav-title {
  color: #1F2937;
}

.theme-light .card {
  background: rgba(255, 255, 255, 0.85);
  border-color: rgba(0, 0, 0, 0.06);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.theme-light .card-title {
  color: #1F2937;
}

.theme-light .balance-label {
  color: #6B7280;
}

.theme-light .balance-value.intake {
  color: #C49A6C;
}

.theme-light .balance-value.burn {
  color: #4A9B8A;
}

.theme-light .balance-unit {
  color: #9CA3AF;
}

.theme-light .balance-diff.surplus-minus {
  color: #4A9B8A;
  background: rgba(74, 155, 138, 0.1);
}

.theme-light .balance-diff.surplus-plus {
  color: #C49A6C;
  background: rgba(196, 154, 108, 0.1);
}

.theme-light .balance-detail {
  border-top-color: rgba(0, 0, 0, 0.06);
}

.theme-light .balance-detail-text {
  color: #6B7280;
}

.theme-light .step-refresh {
  color: #4A9B8A;
  background: rgba(74, 155, 138, 0.1);
}

.theme-light .step-count {
  color: #1F2937;
}

.theme-light .step-unit {
  color: #6B7280;
}

.theme-light .step-cal-value {
  color: #4A9B8A;
}

.theme-light .step-cal-unit {
  color: #6B7280;
}

.theme-light .step-hint {
  border-top-color: rgba(0, 0, 0, 0.06);
  color: #6B7280;
}

.theme-light .group-header {
  border-bottom-color: rgba(0, 0, 0, 0.06);
}

.theme-light .group-date {
  color: #1F2937;
}

.theme-light .group-cal {
  color: #4A9B8A;
}

.theme-light .exercise-item {
  border-bottom-color: rgba(0, 0, 0, 0.04);
}

.theme-light .ex-icon {
  background: rgba(0, 0, 0, 0.04);
}

.theme-light .ex-name {
  color: #1F2937;
}

.theme-light .ex-detail {
  color: #6B7280;
}

.theme-light .ex-delete:active {
  background: rgba(184, 123, 123, 0.15);
}

.theme-light .icon-close-small::before,
.theme-light .icon-close-small::after {
  background: #9CA3AF;
}

.theme-light .fab-add {
  background: linear-gradient(135deg, #4A9B8A, #3D8B7A);
  box-shadow: 0 8rpx 32rpx rgba(74, 155, 138, 0.35);
}

/* 弹窗浅色 */
.theme-light.add-popup {
  background: #FFFFFF;
  border-top-color: rgba(0, 0, 0, 0.08);
}

.theme-light.add-popup .popup-title {
  color: #1F2937;
}

.theme-light.add-popup .icon-close::before,
.theme-light.add-popup .icon-close::after {
  background: #6B7280;
}

.theme-light.add-popup .form-label {
  color: #6B7280;
}

.theme-light.add-popup .form-input {
  background: #F0F4F3;
  border-color: #E5E7EB;
  color: #1F2937;
}

.theme-light.add-popup .type-item {
  background: #F0F4F3;
  border-color: #E5E7EB;
}

.theme-light.add-popup .type-item.active {
  background: rgba(74, 155, 138, 0.1);
  border-color: #4A9B8A;
}

.theme-light.add-popup .type-label {
  color: #1F2937;
}

.theme-light.add-popup .popup-btn-cancel {
  background: #E5E7EB;
  color: #6B7280;
}

.theme-light.add-popup .popup-btn-confirm {
  background: #4A9B8A;
  box-shadow: 0 4rpx 16rpx rgba(74, 155, 138, 0.2);
}

.theme-light .toast {
  background: #FFFFFF;
  border-color: rgba(74, 155, 138, 0.3);
  color: #4A9B8A;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

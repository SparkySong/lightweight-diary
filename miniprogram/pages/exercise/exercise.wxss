/* pages/exercise/exercise.wxss - Vant组件版 */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  padding-top: calc(env(safe-area-inset-top) + 44px);
  min-height: 100vh;
}

.custom-nav-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 44px);
  background-color: var(--nav-bg, #121212);
  z-index: 9999;
}

.theme-light .custom-nav-area,
page.theme-light {
  --nav-bg: #F8FAF9;
}

.theme-dark .custom-nav-area,
page.theme-dark {
  --nav-bg: #121212;
}

/* 卡片标题 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
}

/* 热量收支 */
.balance-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 16rpx;
}

.balance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.balance-label {
  font-size: 24rpx;
}

.balance-value {
  font-size: 40rpx;
  font-weight: 700;
}

.balance-value.intake {
  color: var(--color-primary);
}

.balance-value.burn {
  color: var(--color-warning);
}

.balance-unit {
  font-size: 22rpx;
}

.balance-divider {
  display: flex;
  align-items: center;
}

.balance-diff {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-md);
}

.balance-diff.surplus-minus {
  background: rgba(34, 197, 94, 0.1);
}

.balance-diff.surplus-plus {
  background: rgba(239, 68, 68, 0.1);
}

.balance-diff-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.balance-diff-val {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.balance-detail {
  text-align: center;
  font-size: 22rpx;
}

/* 步数卡片 */
.step-card {
  /* 继承 mint-card */
}

.step-refresh {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.step-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 16rpx;
}

.step-main {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.step-count {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.step-unit {
  font-size: 24rpx;
}

.step-cal {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.step-cal-value {
  font-size: 28rpx;
  font-weight: 600;
}

.step-cal-unit {
  font-size: 22rpx;
}

.step-hint {
  text-align: center;
  font-size: 22rpx;
}

/* 运动记录 */
.exercise-groups {
  margin-top: 16rpx;
}

.exercise-group {
  margin-bottom: 24rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.group-date {
  font-size: 26rpx;
  font-weight: 600;
}

.group-cal {
  font-size: 24rpx;
}

.exercise-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.exercise-item:last-child {
  border-bottom: none;
}

.ex-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.ex-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.ex-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ex-name {
  font-size: 28rpx;
  font-weight: 500;
}

.ex-detail {
  font-size: 22rpx;
}

/* FAB */
.fab-add {
  position: fixed;
  right: 30rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 155, 138, 0.4);
  z-index: 100;
}

.fab-add:active {
  transform: scale(0.92);
}

/* 弹窗表单 */
.dialog-form {
  padding: 20rpx 0;
}

.dialog-section {
  padding: 20rpx 32rpx;
}

.dialog-label {
  font-size: 26rpx;
  display: block;
  margin-bottom: 16rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 底部 */
.footer-space {
  height: 200rpx;
}

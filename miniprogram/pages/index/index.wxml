<!--pages/index/index.wxml-->
<page class="{{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}" bindtap="onPageTap" catchtap="onCancelGoalInput">
<!-- 页面元信息，在 JS 中动态设置背景色和状态栏 -->
<page-meta 
  background-text-style="{{currentTheme === 'light' ? 'dark' : 'light'}}" 
  background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}" 
  background-color-top="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}" 
  background-color-bottom="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}" 
  navigation-bar-style="{{currentTheme === 'light' ? 'dark' : 'light'}}"
/>

<!-- 自定义导航栏区域 -->
<view class="custom-nav-area"></view>

<view class="container {{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}">
  <!-- Header -->
  <view class="header">
    <view class="header-title-row">
      <text class="title">打卡记录</text>
      <view class="header-actions">
        <!-- 主题切换按钮 - 简化为图标 -->
        <view class="theme-toggle" bindtap="onToggleThemeMenu">
          <view class="theme-icon-svg" wx:if="{{currentThemeSetting === 'system'}}">
            <view class="icon-device"></view>
          </view>
          <view class="theme-icon-svg theme-moon" wx:elif="{{currentTheme === 'dark'}}"></view>
          <view class="theme-icon-svg theme-sun" wx:else></view>
        </view>
      </view>
    </view>
    <text class="subtitle" wx:if="{{streak > 0}}">
      <view class="streak-icon"></view>
      已连续打卡 {{streak}} 天
    </text>
    <text class="subtitle" wx:else>坚持记录，遇见更好的自己</text>
    
    <!-- 主题选择菜单 -->
    <view class="theme-menu" wx:if="{{showThemeMenu}}">
      <view class="theme-menu-item {{currentThemeSetting === 'system' ? 'active' : ''}}" 
            bindtap="onSwitchTheme" data-theme="system">
        <view class="theme-menu-icon icon-device-small"></view>
        <text class="theme-menu-text">跟随系统</text>
      </view>
      <view class="theme-menu-item {{currentThemeSetting === 'dark' ? 'active' : ''}}" 
            bindtap="onSwitchTheme" data-theme="dark">
        <view class="theme-menu-icon icon-moon-small"></view>
        <text class="theme-menu-text">深色模式</text>
      </view>
      <view class="theme-menu-item {{currentThemeSetting === 'light' ? 'active' : ''}}" 
            bindtap="onSwitchTheme" data-theme="light">
        <view class="theme-menu-icon icon-sun-small"></view>
        <text class="theme-menu-text">浅色模式</text>
      </view>
    </view>
  </view>

  <!-- Stats Cards - 简化为三列核心数据 -->
  <view class="stats">
    <view class="stat-card" bindtap="openWeightPopup" data-type="current">
      <text class="stat-label">当前体重</text>
      <view class="stat-value-wrap">
        <text class="stat-value">{{currentWeight}}</text>
        <text class="stat-unit" wx:if="{{currentWeight !== '--'}}">{{weightUnitLabel}}</text>
      </view>
      <text class="stat-change {{lastChangeClass}}">{{lastChange}}</text>
    </view>
    <view class="stat-card" bindtap="openWeightPopup" data-type="target">
      <text class="stat-label">目标体重</text>
      <view class="stat-value-wrap">
        <text class="stat-value">{{goalWeight || '--'}}</text>
        <text class="stat-unit" wx:if="{{goalWeight}}">{{weightUnitLabel}}</text>
      </view>
      <text class="stat-change neutral" wx:if="{{!goalWeight}}">未设置</text>
      <text class="stat-change {{goalReached ? 'down' : 'neutral'}}" wx:else>{{goalRemaining}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">已减</text>
      <view class="stat-value-wrap">
        <text class="stat-value" style="color:{{totalLostColor}}">{{totalLost}}</text>
        <text class="stat-unit" wx:if="{{totalLost !== '--'}}">{{weightUnitLabel}}</text>
      </view>
      <text class="stat-change neutral">{{daysCount}} 天</text>
    </view>
  </view>

  <!-- BMI Card - 优化进度条设计 -->
  <view class="card bmi-card">
    <view class="card-header">
      <view class="card-title-wrap">
        <view class="title-icon icon-chart"></view>
        <text class="card-title">BMI 指数</text>
      </view>
      <text class="bmi-badge" style="background:{{bmiBgColor}};color:{{bmiColor}}">{{bmiCategory}}</text>
    </view>
    <view class="bmi-content">
      <view class="bmi-value-wrap">
        <text class="bmi-number" style="color:{{bmiColor}}">{{bmiValue}}</text>
        <text class="bmi-range">正常范围 18.5-24</text>
      </view>
      <!-- 优化后的BMI分段进度条 -->
      <view class="bmi-track">
        <view class="bmi-segment underweight"></view>
        <view class="bmi-segment normal"></view>
        <view class="bmi-segment overweight"></view>
        <view class="bmi-segment obese"></view>
        <view class="bmi-indicator" wx:if="{{bmiValue !== '--'}}" style="left: {{bmiIndicatorLeft}}%;"></view>
      </view>
      <view class="bmi-labels">
        <text class="bmi-label" data-range="偏瘦">偏瘦</text>
        <text class="bmi-label" data-range="正常">正常</text>
        <text class="bmi-label" data-range="偏胖">偏胖</text>
        <text class="bmi-label" data-range="肥胖">肥胖</text>
      </view>
    </view>
    <!-- Height Setting -->
    <view class="height-section">
      <view wx:if="{{height && !showHeightInput}}" class="height-display">
        <text class="height-val">身高: {{height}} cm</text>
        <text class="height-edit" bindtap="onEditHeight">修改</text>
      </view>
      <view wx:else class="height-input-wrap" catchtap="stopPropagation">
        <input id="height-input" class="height-input" type="digit" placeholder="身高 (cm)" value="{{inputHeight}}" bindinput="onHeightInput" />
        <button id="height-btn" class="btn-sm" bindtap="onSetHeight">保存</button>
      </view>
    </view>
  </view>

  <!-- Chart - 优化趋势图 -->
  <view class="card chart-card">
    <view class="card-header">
      <view class="card-title-wrap">
        <view class="title-icon icon-trend"></view>
        <text class="card-title">体重趋势</text>
      </view>
      <view class="range-btns">
        <view class="range-btn {{chartRange === 7 ? 'active' : ''}}" data-range="7" bindtap="onRangeChange">7天</view>
        <view class="range-btn {{chartRange === 30 ? 'active' : ''}}" data-range="30" bindtap="onRangeChange">30天</view>
        <view class="range-btn {{chartRange === 'all' ? 'active' : ''}}" data-range="all" bindtap="onRangeChange">全部</view>
      </view>
    </view>
    <canvas canvas-id="chart" id="chart" class="chart-canvas" />
  </view>

  <!-- Checkin - 优化打卡区域 -->
  <view class="card checkin-card">
    <view class="card-title-wrap">
      <view class="title-icon icon-edit"></view>
      <text class="card-title">今日打卡</text>
    </view>
    <view class="input-row">
      <picker mode="date" value="{{inputDate}}" bindchange="onDateChange">
        <view class="picker-btn">{{inputDate || '选择日期'}}</view>
      </picker>
      <view class="weight-input-wrap">
        <text class="weight-placeholder" wx:if="{{!inputWeight}}">体重 ({{weightUnitLabel}})</text>
        <input class="weight-input" type="digit" value="{{inputWeight}}" bindinput="onWeightInput" confirm-type="done" bindconfirm="onCheckin" />
      </view>
    </view>
    <!-- 打卡按钮 -->
<button class="btn-primary btn-capsule" bindtap="onCheckin">
  <text>打卡记录</text>
</button>
  </view>

  <!-- Goal - 优化目标卡片 -->
  <view class="card goal-card" >
    <view class="goal-header">
      <view class="card-title-wrap">
        <view class="title-icon icon-target"></view>
        <text class="card-title">目标体重</text>
      </view>
      <text catchtap="onEditGoal" class="goal-edit-hint" wx:if="{{goalWeight && !showGoalInput}}">
        <view class="edit-icon-small"></view>
        修改
      </text>
    </view>
    <view class="goal-input-wrap" wx:if="{{showGoalInput}}" catchtap="stopPropagation">
      <view class="input-row">
        <view class="goal-input-with-unit">
          <input class="weight-input goal-input" type="digit" placeholder="目标体重" value="{{inputGoal}}" bindinput="onGoalInput" confirm-type="done" bindconfirm="onSetGoal" />
          <text class="goal-input-unit">{{weightUnitLabel}}</text>
        </view>
        <button class="btn-goal" bindtap="onSetGoal">设定</button>
        <view class="btn-cancel-small" bindtap="onCancelGoal">取消</view>
      </view>
    </view>
    <view wx:if="{{goalWeight && !showGoalInput}}">
      <view class="goal-display">
        <text class="goal-val">{{goalWeight}} {{weightUnitLabel}}</text>
        <text class="goal-remaining {{goalReached ? 'down' : ''}}">{{goalRemaining}}</text>
      </view>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{goalProgressWidth}}%;"></view>
      </view>
    </view>
    <view class="goal-empty" wx:if="{{!goalWeight && !showGoalInput}}">
      <view class="empty-icon icon-target-outline"></view>
      <text>点击设置目标体重</text>
    </view>
  </view>

  <!-- Quick Actions - 优化快捷操作 -->
  <view class="quick-actions">
    <view class="action-card" bindtap="goToDiet">
      <view class="action-icon icon-food"></view>
      <text class="action-label">饮食记录</text>
      <text class="action-desc">记录每日饮食</text>
    </view>
    <view class="action-card" bindtap="onToggleReminder">
      <view class="action-icon {{reminderEnabled ? 'icon-bell' : 'icon-bell-off'}}"></view>
      <text class="action-label">{{reminderEnabled ? '提醒已开启' : '开启提醒'}}</text>
      <text class="action-desc" wx:if="{{reminderEnabled}}">每天 {{remindTime}}</text>
      <view class="time-picker-wrap" wx:if="{{reminderEnabled}}" catchtap="onTimePickerTap">
        <picker mode="time" value="{{remindTime}}" bindchange="onRemindTimeChange">
          <text class="action-link">修改时间</text>
        </picker>
      </view>
    </view>
  </view>

  <!-- History - 优化记录列表 -->
  <view class="card history-card">
    <view class="card-title-wrap">
      <view class="title-icon icon-list"></view>
      <text class="card-title">打卡记录</text>
    </view>
    <view class="empty-state" wx:if="{{records.length === 0}}">
      <view class="empty-icon icon-inbox"></view>
      <text class="empty-text">还没有记录，开始你的第一次打卡吧</text>
    </view>
    
    <!-- 记录列表滚动容器 -->
    <scroll-view 
      class="records-scroll"
      scroll-y
      enhanced
      disable-scroll
      bindscrolltolower="onRecordsScrollToLower"
      lower-threshold="100"
      wx:if="{{records.length > 0}}">
      <view class="record-list">
        <view class="record-item" wx:for="{{records}}" wx:key="_id" wx:for-item="record" data-record="{{record}}" bindtap="onEditRecord">
          <view class="record-left">
            <text class="record-date">{{record.dateStr}}</text>
            <text class="record-weight">{{record.displayWeight || record.weight}} {{weightUnitLabel}}</text>
          </view>
          <view class="record-right">
            <view class="record-diff {{record.diffClass}}" wx:if="{{record.displayDiff !== undefined && record.displayDiff !== null}}">
              <block wx:if="{{record.displayDiff < 0}}">
                <view class="trend-icon trend-down"></view>
                <text>{{(-record.displayDiff)}}</text>
              </block>
              <block wx:elif="{{record.displayDiff > 0}}">
                <view class="trend-icon trend-up"></view>
                <text>{{record.displayDiff}}</text>
              </block>
              <block wx:else>
                <view class="trend-icon trend-flat"></view>
              </block>
            </view>
            <view class="edit-icon" catchtap="onEditRecord" data-record="{{record}}">
              <view class="icon-edit-small"></view>
            </view>
            <view class="delete-btn" data-id="{{record._id}}" data-date="{{record.date}}" catchtap="onDelete">
              <view class="icon-delete"></view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 加载更多提示 -->
      <view class="load-more" wx:if="{{hasMoreRecords || isLoadingMore}}">
        <view class="loading-spinner" wx:if="{{isLoadingMore}}"></view>
        <text class="load-more-text" wx:if="{{isLoadingMore}}">加载中...</text>
        <text class="load-more-text" wx:elif="{{!hasMoreRecords}}">— 已加载全部 —</text>
      </view>
    </scroll-view>
  </view>

  <view class="footer">
    <text>每天进步一点点</text>
  </view>
</view>

<!-- 编辑身高时的遮罩层（仅在修改已有身高时显示，首次设置不显示） -->
<view class="height-edit-mask {{showHeightInput && height ? 'show' : ''}} {{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}" bindtap="onMaskTap"></view>

<!-- 编辑体重弹窗 -->
<view class="edit-panel-mask {{showEditPanel ? 'show' : ''}} {{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}" bindtap="closeEditPanel"></view>
<view class="edit-panel {{showEditPanel ? 'show' : ''}} {{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}">
  <view class="edit-panel-header">
    <view class="panel-title-wrap">
      <view class="title-icon icon-edit"></view>
      <text class="edit-panel-title">修改体重</text>
    </view>
    <text class="edit-panel-date">{{editDate}}</text>
  </view>
  <view class="edit-panel-content">
    <input class="edit-weight-input" type="digit" placeholder="体重 ({{weightUnitLabel}})" value="{{editWeight}}" bindinput="onEditWeightInput" confirm-type="done" bindconfirm="onSaveEdit" />
  </view>
  <view class="edit-panel-actions">
    <button class="btn-cancel" bindtap="closeEditPanel">取消</button>
    <button class="btn-save" bindtap="onSaveEdit">保存</button>
  </view>
</view>

<!-- Toast -->
<view class="toast {{toastShow ? 'show' : ''}}">{{toastMsg}}</view>
</page>

<!-- 体重编辑弹框 -->
<view class="weight-popup-overlay {{weightPopupShow ? 'show' : ''}} {{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}" bindtap="closeWeightPopup"></view>
<view class="weight-popup {{weightPopupShow ? 'show' : ''}} {{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}}">
  <view class="weight-popup-header">
    <view class="popup-title-wrap">
      <view class="title-icon {{weightPopupType === 'current' ? 'icon-edit' : 'icon-target'}}"></view>
      <text class="weight-popup-title">{{weightPopupType === 'current' ? (currentWeight !== '--' ? '编辑当前体重' : '记录当前体重') : (goalWeight ? '编辑目标体重' : '设置目标体重')}}</text>
    </view>
    <view class="weight-popup-close" bindtap="closeWeightPopup">
      <view class="icon-close"></view>
    </view>
  </view>
  <view class="weight-popup-body">
    <view class="weight-popup-input-group">
      <text class="weight-popup-label">{{weightPopupType === 'current' ? '当前体重' : '目标体重'}}</text>
      <view class="weight-popup-input-row">
        <input class="weight-popup-input" type="digit" value="{{weightInputValue}}" bindinput="onWeightPopupInput" placeholder="请输入体重" />
        <text class="weight-popup-unit">{{weightUnitLabel}}</text>
      </view>
    </view>
    <view class="weight-popup-error" wx:if="{{weightPopupError}}">{{weightPopupError}}</view>
  </view>
  <view class="weight-popup-footer">
    <button class="weight-popup-btn-cancel" bindtap="closeWeightPopup">取消</button>
    <button class="weight-popup-btn-confirm" bindtap="saveWeightPopup">确认</button>
  </view>
</view>

}

.weight-popup-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 48rpx;
}

.weight-popup-btn-cancel {
  flex: 1;
  padding: 24rpx 0;
  background: #3D3D3D;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.weight-popup-btn-cancel::after {
  border: none;
}

.weight-popup-btn-cancel:active {
  background: #4D4D4D;
}

.weight-popup-btn-confirm {
  flex: 1;
  padding: 24rpx 0;

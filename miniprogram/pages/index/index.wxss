/* pages/index/index.wxss - 现代简约健康App风格 */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

/* 容器基础样式 */
.container {
  padding: 30rpx;
  padding-bottom: 100rpx;
  padding-top: calc(env(safe-area-inset-top) + 44px);
  min-height: 100vh;
}

/* 自定义导航栏 */
.custom-nav-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 44px);
  background-color: var(--nav-bg, #121212);
  z-index: 9999;
}

/* Header */
.header {
  position: relative;
  padding: 20rpx 0 30rpx;
  margin-top: 0;
}

.header-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

/* 主题切换按钮 - 简约圆形 */
.theme-toggle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  transition: all 0.2s ease;
}

.theme-toggle:active {
  background: rgba(255, 255, 255, 0.12);
  transform: scale(0.95);
}

/* 主题图标 - 使用CSS绘制 */
.theme-icon-svg {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.theme-moon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  box-shadow: inset -8rpx -2rpx 0 0 currentColor;
  color: #9CA3AF;
}

.theme-sun {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: currentColor;
  color: #D4A574;
  position: relative;
}

.theme-sun::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid currentColor;
  opacity: 0.3;
}

.icon-device {
  width: 18rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  color: #9CA3AF;
  position: relative;
}

.icon-device::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
}

/* 标题样式 */
.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #F5F5F5;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 24rpx;
  color: #9CA3AF;
}

.streak-icon {
  width: 24rpx;
  height: 24rpx;
  background: linear-gradient(135deg, #D4A574, #C98B8B);
  border-radius: 50%;
  position: relative;
}

.streak-icon::before {
  content: '';
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 10rpx;
  background: white;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
}

/* 主题菜单 */
.theme-menu {
  position: absolute;
  top: 140rpx;
  right: 30rpx;
  background: #1E1E1E;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.4);
  z-index: 1000;
  overflow: hidden;
  min-width: 220rpx;
}

.theme-menu-item {
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: background 0.2s;
}

.theme-menu-item:last-child {
  border-bottom: none;
}

.theme-menu-item.active {
  background: rgba(95, 168, 149, 0.12);
}

.theme-menu-icon {
  width: 28rpx;
  height: 28rpx;
  color: #9CA3AF;
}

.theme-menu-item.active .theme-menu-icon {
  color: #5FA895;
}

.theme-menu-text {
  font-size: 28rpx;
  color: #F5F5F5;
}

/* 菜单图标 */
.icon-device-small {
  width: 16rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 3rpx;
  position: relative;
}

.icon-device-small::after {
  content: '';
  position: absolute;
  bottom: -3rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
}

.icon-moon-small {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  box-shadow: inset -6rpx -2rpx 0 0 currentColor;
}

.icon-sun-small {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: currentColor;
}

/* Stats - 三列核心数据 - 毛玻璃效果 */
.stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: rgba(30, 30, 30, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.18);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.stat-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 400;
  letter-spacing: 0.5rpx;
}

.stat-value-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 6rpx;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #F5F5F5;
  letter-spacing: -0.03em;
}

.stat-unit {
  font-size: 20rpx;
  color: #6B7280;
  font-weight: 400;
}

.stat-change {
  font-size: 22rpx;
  display: block;
  font-weight: 500;
}

.stat-change.down { color: #5FA895; }
.stat-change.up { color: #C98B8B; }
.stat-change.neutral { color: #6B7280; }

/* Card 基础样式 - 毛玻璃效果 */
.card {
  background: rgba(30, 30, 30, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #F5F5F5;
}

/* 标题图标 */
.title-icon {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-chart {
  width: 24rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-top: none;
  border-right: none;
  position: relative;
  color: #9CA3AF;
}

.icon-chart::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 4rpx;
  width: 2rpx;
  height: 8rpx;
  background: currentColor;
}

.icon-chart::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  width: 2rpx;
  height: 12rpx;
  background: currentColor;
}

.icon-trend {
  width: 24rpx;
  height: 16rpx;
  position: relative;
  color: #9CA3AF;
}

.icon-trend::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 2rpx;
  background: currentColor;
  bottom: 0;
  left: 0;
}

.icon-trend::after {
  content: '';
  position: absolute;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 10rpx solid currentColor;
  right: 0;
  bottom: 2rpx;
}

.icon-edit {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
  color: #9CA3AF;
}

.icon-edit::before {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #121212;
  border-left: 2rpx solid currentColor;
  transform: rotate(45deg);
}

.icon-target {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  color: #9CA3AF;
}

.icon-target::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  background: currentColor;
  border-radius: 50%;
}

.icon-list {
  width: 20rpx;
  height: 16rpx;
  position: relative;
  color: #9CA3AF;
}

.icon-list::before,
.icon-list::after {
  content: '';
  position: absolute;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: currentColor;
  box-shadow: 0 7rpx 0 currentColor;
}

.icon-list::before { top: 0; }
.icon-list::after { top: 4rpx; }

/* BMI Card - 优化设计 */
.bmi-card .card-header {
  margin-bottom: 16rpx;
}

.bmi-badge {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.bmi-content {
  margin-bottom: 16rpx;
}

.bmi-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.bmi-number {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.bmi-range {
  font-size: 22rpx;
  color: #6B7280;
}

/* BMI分段进度条 - 更精致的分段设计 */
.bmi-track {
  height: 8rpx;
  border-radius: 4rpx;
  display: flex;
  position: relative;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  overflow: visible;
}

.bmi-segment {
  flex: 1;
  height: 100%;
  opacity: 0.4;
  transition: opacity 0.3s;
}

.bmi-segment.underweight { background: #6B7280; }
.bmi-segment.normal { background: #5FA895; }
.bmi-segment.overweight { background: #D4A574; }
.bmi-segment.obese { background: #C98B8B; }

/* 激活状态 */
.bmi-segment.active {
  opacity: 0.9;
}

.bmi-indicator {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  background: #F5F5F5;
  border-radius: 50%;
  border: 4rpx solid #121212;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.35);
  transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.bmi-labels {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #6B7280;
}

.bmi-label {
  position: relative;
}

/* Height */
.height-section {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.height-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.height-val {
  font-size: 24rpx;
  color: #9CA3AF;
}

.height-edit {
  font-size: 24rpx;
  color: #5FA895;
  font-weight: 500;
}

.height-input-wrap {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.height-input {
  flex: 1;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  color: #F5F5F5;
  font-size: 28rpx;
  text-align: center;
}

.height-input::placeholder {
  color: #6B7280;
  font-size: 24rpx;
}

.btn-sm {
  background: #5FA895;
  border: none;
  border-radius: 12rpx;
  color: white;
  font-size: 24rpx;
  font-weight: 500;
  padding: 14rpx 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(95, 168, 149, 0.25);
}

.btn-sm::after { border: none; }

.btn-sm:active {
  opacity: 0.85;
}

/* Range Buttons */
.range-btns {
  display: flex;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 4rpx;
}

.range-btn {
  background: transparent;
  color: #9CA3AF;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.range-btn.active {
  background: #5FA895;
  color: white;
}

/* Chart */
.chart-card {
  padding-bottom: 20rpx;
}

.chart-canvas {
  width: 100%;
  height: 360rpx;
}

/* Checkin Card */
.checkin-card .card-title-wrap {
  margin-bottom: 20rpx;
}

/* Input */
.input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.picker-btn {
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  color: #F5F5F5;
  font-size: 26rpx;
  min-width: 200rpx;
  text-align: center;
  font-weight: 500;
}

.weight-input-wrap {
  flex: 1;
  position: relative;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 12rpx;
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.weight-placeholder {
  color: #6B7280;
  font-size: 26rpx;
  position: absolute;
  pointer-events: none;
}

.weight-input {
  width: 100%;
  background: transparent;
  border: none;
  padding: 18rpx 20rpx;
  color: #F5F5F5;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

/* Buttons - 胶囊形打卡按钮 */
.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #5FA895, #6B9E8F);
  border: none;
  border-radius: 50rpx;
  color: white;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx 0;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 20rpx rgba(95, 168, 149, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-primary::after { border: none; }

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(95, 168, 149, 0.2);
}

.btn-goal {
  background: #5FA895;
  border: none;
  border-radius: 12rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 500;
  width: 140rpx;
  padding: 16rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(95, 168, 149, 0.25);
}

.btn-goal::after { border: none; }

.btn-goal:active {
  opacity: 0.85;
}

.btn-cancel-small {
  background: #3D3D3D;
  border-radius: 12rpx;
  color: #9CA3AF;
  font-size: 26rpx;
  font-weight: 500;
  width: 100rpx;
  text-align: center;
  height: 76rpx;
  line-height: 76rpx;
}

/* Goal */
.goal-input-wrap { margin-bottom: 8rpx; }
.goal-input { flex: 1; }
.goal-input-with-unit {
  display: flex;
  align-items: center;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 76rpx;
  flex: 1;
}
.goal-input-with-unit .goal-input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 0;
  height: 100%;
}
.goal-input-unit {
  font-size: 26rpx;
  color: #6B7280;
  margin-left: 8rpx;
  font-weight: 500;
}
.goal-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.goal-val {
  font-size: 34rpx;
  font-weight: 700;
  color: #D4A574;
}
.goal-remaining {
  font-size: 24rpx;
  color: #6B7280;
}
.goal-remaining.down { color: #5FA895; }
.progress-bar {
  width: 100%;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3rpx;
  margin-top: 16rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 3rpx;
  background: linear-gradient(90deg, #5FA895, #6B8E9F);
  transition: width 0.5s ease;
}

/* 目标卡片 */
.goal-card {
  cursor: pointer;
  transition: transform 0.2s;
}
.goal-card:active {
  transform: scale(0.98);
}
.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.goal-edit-hint {
  font-size: 22rpx;
  color: #5FA895;
  opacity: 0.8;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.edit-icon-small {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
}

.edit-icon-small::before {
  content: '';
  position: absolute;
  top: -3rpx;
  right: -3rpx;
  width: 6rpx;
  height: 6rpx;
  background: #1E1E1E;
  border-left: 2rpx solid currentColor;
  transform: rotate(45deg);
}

.goal-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #6B7280;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.5;
}

.icon-target-outline {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}

.icon-target-outline::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

/* Quick Actions - 毛玻璃效果 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.action-card {
  flex: 1;
  background: rgba(30, 30, 30, 0.75);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.18);
  text-align: center;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.action-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5FA895;
}

.icon-food {
  width: 28rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  position: relative;
}

.icon-food::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 6rpx;
  background: currentColor;
  border-radius: 50% 50% 0 0;
}

.icon-bell {
  width: 24rpx;
  height: 28rpx;
  border: 2rpx solid currentColor;
  border-radius: 12rpx 12rpx 0 0;
  border-bottom: none;
  position: relative;
}

.icon-bell::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-bell::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
}

.icon-bell-off {
  width: 24rpx;
  height: 28rpx;
  border: 2rpx solid #6B7280;
  border-radius: 12rpx 12rpx 0 0;
  border-bottom: none;
  position: relative;
  color: #6B7280;
}

.icon-bell-off::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-bell-off::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
}

.action-label {
  font-size: 26rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
  color: #F5F5F5;
}
.action-desc {
  font-size: 20rpx;
  color: #6B7280;
  display: block;
}
.action-link {
  font-size: 22rpx;
  color: #5FA895;
  margin-top: 8rpx;
  display: block;
  font-weight: 500;
}

.time-picker-wrap {
  pointer-events: auto !important;
}

.time-picker-wrap .action-link {
  display: inline-block;
  background: rgba(95, 168, 149, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(95, 168, 149, 0.25);
  transition: all 0.2s;
}

.time-picker-wrap .action-link:active {
  background: rgba(95, 168, 149, 0.2);
  transform: scale(0.95);
}

/* History */
.history-card { padding-bottom: 10rpx; }

.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.icon-inbox {
  width: 64rpx;
  height: 56rpx;
  border: 2rpx solid #6B7280;
  border-radius: 4rpx 4rpx 12rpx 12rpx;
  position: relative;
  opacity: 0.5;
}

.icon-inbox::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 10rpx;
  border: 2rpx solid #6B7280;
  border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
}

.empty-text {
  font-size: 26rpx;
  color: #6B7280;
}

.record-list { margin-top: 8rpx; }

/* 记录列表滚动容器 - 隐藏滚动条 */
.records-scroll {
  height: 720rpx;
  margin-top: 8rpx;
}

/* 隐藏滚动条 */
.records-scroll::-webkit-scrollbar {
  display: none;
}
.records-scroll {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  gap: 12rpx;
}
.load-more-text {
  font-size: 24rpx;
  color: #6B7280;
}
.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #5FA895;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}
.record-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.record-date {
  font-size: 24rpx;
  color: #6B7280;
}
.record-weight {
  font-size: 32rpx;
  font-weight: 600;
  color: #F5F5F5;
}
.record-right {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.record-diff {
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 6rpx;
  line-height: 1;
  min-width: 90rpx;
  justify-content: flex-end;
}
.record-diff.down { color: #5FA895; }
.record-diff.up { color: #C98B8B; }
.record-diff.neutral { color: #6B7280; }

/* 趋势图标 */
.trend-icon {
  width: 12rpx;
  height: 12rpx;
}

.trend-down {
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 10rpx solid currentColor;
}

.trend-up {
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 10rpx solid currentColor;
}

.trend-flat {
  width: 10rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}
.delete-btn:active { 
  background: rgba(201, 139, 139, 0.15);
}

.icon-delete {
  width: 16rpx;
  height: 16rpx;
  position: relative;
}

.icon-delete::before,
.icon-delete::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 2rpx;
  background: #6B7280;
  border-radius: 1rpx;
}

.icon-delete::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-delete::after { transform: translate(-50%, -50%) rotate(-45deg); }

.delete-btn:active .icon-delete::before,
.delete-btn:active .icon-delete::after {
  background: #C98B8B;
}

/* 编辑图标 */
.edit-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}
.edit-icon:active { 
  background: rgba(95, 168, 149, 0.15);
}

.icon-edit-small {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid #6B7280;
  border-radius: 2rpx;
  position: relative;
}

.icon-edit-small::before {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 8rpx;
  height: 8rpx;
  background: #1E1E1E;
  border-left: 2rpx solid #6B7280;
  transform: rotate(45deg);
}

.edit-icon:active .icon-edit-small {
  border-color: #5FA895;
}

.edit-icon:active .icon-edit-small::before {
  border-left-color: #5FA895;
  background: rgba(95, 168, 149, 0.15);
}

/* 编辑体重弹窗 */
.edit-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.edit-panel-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.edit-panel {
  position: fixed;
  bottom: -600rpx;
  left: 30rpx;
  right: 30rpx;
  background: #1E1E1E;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  z-index: 1000;
  transition: bottom 0.3s ease;
  margin-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}
.edit-panel.show {
  bottom: 0;
}

.edit-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.panel-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.edit-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #F5F5F5;
}
.edit-panel-date {
  font-size: 26rpx;
  color: #6B7280;
}
.edit-panel-content {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.edit-weight-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 16rpx;
  padding: 0 24rpx;
  color: #F5F5F5;
  font-size: 40rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}
.edit-weight-input::placeholder {
  color: #6B7280;
  font-weight: 400;
  font-size: 28rpx;
}
.edit-panel-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}
.btn-cancel {
  flex: 1;
  background: #3D3D3D;
  border: none;
  border-radius: 16rpx;
  color: #9CA3AF;
  font-size: 28rpx;
  font-weight: 500;
  padding: 22rpx 0;
}
.btn-cancel::after { border: none; }
.btn-save {
  flex: 2;
  background: #5FA895;
  border: none;
  border-radius: 16rpx;
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  padding: 22rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(95, 168, 149, 0.25);
}
.btn-save::after { border: none; }
.btn-save:active {
  opacity: 0.85;
}

/* 编辑身高遮罩层 */
.height-edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.height-edit-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* Footer */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 24rpx;
  color: #4B5563;
}

/* ========== AI 营养师浮动入口 ========== */
.ai-fab {
  position: fixed;
  left: 0;
  top: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 100;
  transition: left 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ai-fab.dragging {
  transition: none;
}

.ai-fab-inner {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5FA895, #6B8E9F);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(95, 168, 149, 0.35);
  animation: fabBreathe 3s ease-in-out infinite;
  transition: transform 0.2s;
}

.ai-fab:active .ai-fab-inner {
  transform: scale(0.9);
  animation: none;
}

@keyframes fabBreathe {
  0%, 100% {
    box-shadow: 0 8rpx 28rpx rgba(95, 168, 149, 0.35);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 12rpx 40rpx rgba(95, 168, 149, 0.5);
    transform: scale(1.06);
  }
}

.ai-fab-emoji {
  font-size: 44rpx;
}

.ai-fab-label {
  font-size: 20rpx;
  color: #5FA895;
  margin-top: 6rpx;
  font-weight: 500;
}

/* 浅色主题 */
.ai-fab.theme-light .ai-fab-inner {
  background: linear-gradient(135deg, #4A9B8A, #5A7D8C);
  box-shadow: 0 8rpx 28rpx rgba(74, 155, 138, 0.25);
}

.ai-fab.theme-light .ai-fab-label {
  color: #4A9B8A;
}

@keyframes fabBreatheLight {
  0%, 100% {
    box-shadow: 0 8rpx 28rpx rgba(74, 155, 138, 0.25);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 12rpx 40rpx rgba(74, 155, 138, 0.4);
    transform: scale(1.06);
  }
}

.ai-fab.theme-light .ai-fab-inner {
  animation: fabBreatheLight 3s ease-in-out infinite;
}

/* Toast */
.toast {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 100rpx);
  left: 50%;
  transform: translateX(-50%) translateY(-200rpx);
  background: #1E1E1E;
  border: 1rpx solid rgba(95, 168, 149, 0.3);
  color: #5FA895;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  z-index: 100;
  transition: transform 0.3s ease;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* ========== 体重编辑弹框样式 ========== */

/* 顶部滑出弹框遮罩 */
.weight-popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 99998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.weight-popup-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* 顶部滑出弹框 */
.weight-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #1E1E1E;
  border-radius: 0 0 32rpx 32rpx;
  z-index: 99999;
  transform: translateY(-600px);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
  margin-top: calc(env(safe-area-inset-top) + 44px);
}

.weight-popup.show {
  transform: translateY(0);
}

.weight-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.popup-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.weight-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.weight-popup-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.weight-popup-close:active {
  background: rgba(255, 255, 255, 0.08);
}

.icon-close {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.icon-close::before,
.icon-close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 2rpx;
  background: #9CA3AF;
  border-radius: 1rpx;
}

.icon-close::before { transform: translate(-50%, -50%) rotate(45deg); }
.icon-close::after { transform: translate(-50%, -50%) rotate(-45deg); }

.weight-popup-body {
  padding: 32rpx;
}

.weight-popup-input-group {
  margin-bottom: 24rpx;
}

.weight-popup-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #F5F5F5;
  display: block;
  margin-bottom: 16rpx;
}

.weight-popup-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weight-popup-input {
  flex: 1;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.weight-popup-unit {
  font-size: 32rpx;
  color: #6B7280;

/* pages/index/index.wxss */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

/* 安全区域适配 */
/* 页面背景由主题CSS控制 */
/* page的background-color已通过page.theme-light/page.theme-dark设置 */

.container {
  padding: 30rpx;
  padding-bottom: 100rpx;
  /* 使用安全区域避免与系统状态栏重叠，同时考虑胶囊按钮高度 */
  padding-top: calc(env(safe-area-inset-top) + 44px);
  min-height: 100vh;
}

/* 自定义导航栏区域 - 跟随主题颜色 */
/* 增加额外高度，避免被iOS胶囊按钮遮挡 */
.custom-nav-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 44px);
  background-color: var(--nav-bg, #0f0f13);
  z-index: 9999;
}

/* 云端状态提示 */
.cloud-status {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 44px);
  left: 0;
  right: 0;
  z-index: 9998;
  background-color: var(--error-bg, rgba(225, 112, 85, 0.1));
  border-bottom: 1px solid var(--error-border, rgba(225, 112, 85, 0.3));
  padding: 10rpx 30rpx;
  transition: opacity 0.3s;
}

.cloud-status-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0;
}

.cloud-status-icon {
  font-size: 14px;
  margin-right: 10rpx;
}

.cloud-status-text {
  flex: 1;
  font-size: 12px;
  color: var(--error-text, #e17055);
  line-height: 1.4;
}

.cloud-retry-btn {
  margin-left: 20rpx;
  padding: 6rpx 20rpx;
  font-size: 11px;
  background-color: rgba(225, 112, 85, 0.15);
  border: 1px solid rgba(225, 112, 85, 0.4);
  color: #e17055;
  border-radius: 4px;
  line-height: 1.2;
}

/* 主题适配 */
.theme-light .custom-nav-area,
.theme-light page {
  --nav-bg: #f8f9fa;
}

.theme-dark .custom-nav-area,
.theme-dark page {
  --nav-bg: #0f0f13;
}

.theme-light .cloud-status {
  background-color: rgba(225, 112, 85, 0.08);
  border-bottom: 1px solid rgba(225, 112, 85, 0.2);
}

.theme-light .cloud-retry-btn {
  background-color: rgba(225, 112, 85, 0.1);
  border: 1px solid rgba(225, 112, 85, 0.3);
}

/* Header */
.header {
  position: relative;
  padding: 30rpx 0 30rpx;
  /* 减少上边距，因为我们已经通过container的padding-top提供了足够的安全距离 */
  margin-top: 0;
}

.header-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.theme-toggle, .refresh-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  transition: transform 0.2s;
}

.theme-toggle:active, .refresh-btn:active {
  transform: scale(0.95);
}

.theme-icon, .refresh-icon {
  font-size: 32rpx;
}

.refresh-btn.refreshing .refresh-icon {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 主题菜单 */
.theme-menu {
  position: absolute;
  top: 140rpx; /* 提高位置，避免与自定义导航栏重叠 */
  right: 30rpx;
  background: #1a1a24;
  border-radius: 16rpx;
  border: 1rpx solid #2a2a3a;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  z-index: 1000;
  overflow: hidden;
  min-width: 200rpx;
}

.theme-menu-item {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid #2a2a3a;
}

.theme-menu-item:last-child {
  border-bottom: none;
}

.theme-menu-item.active {
  background: rgba(108, 92, 231, 0.2);
}

.theme-menu-icon {
  font-size: 32rpx;
}

.theme-menu-text {
  font-size: 28rpx;
  color: #e8e8ef;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #a29bfe, #00b894);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: block;
  text-align: left;
  margin-bottom: 8rpx;
}
.subtitle {
  font-size: 24rpx;
  color: #8888a0;
}

/* Stats */
.stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  flex: 1;
  background: #1a1a24;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid #2a2a3a;
}
.stat-label {
  font-size: 20rpx;
  color: #8888a0;
  display: block;
  margin-bottom: 8rpx;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8e8ef;
}
.stat-unit {
  font-size: 20rpx;
  color: #8888a0;
  margin-left: 4rpx;
}
.stat-change {
  font-size: 22rpx;
  display: block;
  margin-top: 6rpx;
}
.stat-change.down { color: #00b894; }
.stat-change.up { color: #e17055; }
.stat-change.neutral { color: #8888a0; }

/* Card */
.card {
  background: #1a1a24;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #2a2a3a;
  margin-bottom: 20rpx;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}
.card-header .card-title {
  margin-bottom: 0;
}
.card-title-wrap {
  margin-bottom: 16rpx;
}

/* BMI */
.bmi-card .card-header {
  margin-bottom: 16rpx;
}
.bmi-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}
.bmi-content {
  margin-bottom: 16rpx;
}
.bmi-value-wrap {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.bmi-number {
  font-size: 56rpx;
  font-weight: 800;
}
.bmi-range {
  font-size: 22rpx;
  color: #8888a0;
}
.bmi-bar {
  height: 12rpx;
  border-radius: 6rpx;
  display: flex;
  overflow: hidden;
  position: relative;
  margin-bottom: 8rpx;
}
.bmi-segment {
  flex: 1;
}
.bmi-segment.underweight { background: #74b9ff; opacity: 0.4; }
.bmi-segment.normal { background: #00b894; opacity: 0.6; }
.bmi-segment.overweight { background: #fdcb6e; opacity: 0.6; }
.bmi-segment.obese { background: #e17055; opacity: 0.6; }
.bmi-indicator {
  position: absolute;
  top: -4rpx;
  width: 8rpx;
  height: 20rpx;
  background: white;
  border-radius: 4rpx;
  transform: translateX(-50%);
}
.bmi-labels {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: #8888a0;
}

/* Height */
.height-section {
  padding-top: 12rpx;
  border-top: 1rpx solid #2a2a3a;
}
.height-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.height-val {
  font-size: 24rpx;
  color: #8888a0;
}
.height-edit {
  font-size: 24rpx;
  color: #6c5ce7;
}
.height-input-wrap {
  display: flex;
  gap: 12rpx;
  align-items: center;
}
.height-input {
  flex: 1;
  background: #0f0f13;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  color: #e8e8ef;
  font-size: 28rpx;
  text-align: center;
}
.height-input::placeholder {
  color: #8888a0;
  font-size: 24rpx;
}
.btn-sm {
  background: #6c5ce7;
  border: none;
  border-radius: 16rpx;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
}
.btn-sm::after { border: none; }

/* Range Buttons */
.range-btns {
  display: flex;
  gap: 8rpx;
}
.range-btn {
  background: transparent;
  border: 1rpx solid #2a2a3a;
  color: #8888a0;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}
.range-btn.active {
  background: #6c5ce7;
  color: white;
  border-color: #6c5ce7;
}

/* Chart */
.chart-canvas {
  width: 100%;
  height: 380rpx;
}

/* Input */
.input-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  align-items: center;
}
.picker-btn {
  background: #0f0f13;
  border: 1rpx solid #2a2a3a;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  color: #e8e8ef;
  font-size: 26rpx;
  min-width: 200rpx;
  text-align: center;
}
.weight-input-wrap {
  flex: 1;
  position: relative;
  background: #0f0f13;
  border: 1rpx solid #2a2a3a;
  border-radius: 12rpx;
  min-height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.weight-placeholder {
  color: #8888a0;
  font-size: 26rpx;
  position: absolute;
  pointer-events: none;
}
.weight-input {
  width: 100%;
  background: transparent;
  border: none;
  padding: 18rpx 20rpx;
  color: #e8e8ef;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}
.weight-input::placeholder {
  color: transparent;
}

/* Buttons */
.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #6c5ce7, #5a4bd1);
  border: none;
  border-radius: 20rpx;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
}
.btn-primary::after { border: none; }

.btn-goal {
  background: #6c5ce7;
  border: none;
  border-radius: 16rpx;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  width: 160rpx;
  padding: 8rpx 28rpx;
}
.btn-goal::after { border: none; }
.btn-cancel-small {
  background: #2a2a3a;
  border-radius: 16rpx;
  color: #8888a0;
  font-size: 26rpx;
  font-weight: 600;
  width: 100rpx;
  text-align: center;
  height: 47rpx;
 line-height: 47rpx;
  padding: 16rpx 28rpx;
}

/* Goal */
.goal-input-wrap { margin-bottom: 8rpx; }
.goal-input { flex: 1; }
.goal-input-with-unit {
  display: flex;
  align-items: center;
  background: #0f0f13;
  border: 1rpx solid #2a2a3a;
  border-radius: 20rpx;
  padding: 0 20rpx;
  height: 88rpx;
}
.goal-input-with-unit .goal-input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 0;
}
.goal-input-unit {
  font-size: 28rpx;
  color: #8888a0;
  margin-left: 8rpx;
  font-weight: 500;
}
.goal-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.goal-val {
  font-size: 36rpx;
  font-weight: 700;
  color: #fdcb6e;
}
.goal-remaining {
  font-size: 24rpx;
  color: #8888a0;
}
.goal-remaining.down { color: #00b894; }
.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #0f0f13;
  border-radius: 5rpx;
  margin-top: 12rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  background: linear-gradient(90deg, #6c5ce7, #00b894);
  transition: width 0.5s ease;
}

/* 目标卡片点击编辑 */
.goal-card {
  cursor: pointer;
  transition: transform 0.2s;
}
.goal-card:active {
  transform: scale(0.98);
}
.goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.goal-edit-hint {
  font-size: 22rpx;
  color: #6c5ce7;
  opacity: 0.7;
}
.goal-empty {
  text-align: center;
  padding: 30rpx 0;
  color: #8888a0;
  font-size: 28rpx;
}

/* Quick Actions */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.action-card {
  flex: 1;
  background: #1a1a24;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  border: 1rpx solid #2a2a3a;
  text-align: center;
}
.action-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}
.action-label {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}
.action-desc {
  font-size: 20rpx;
  color: #8888a0;
  display: block;
}
.action-link {
  font-size: 22rpx;
  color: #6c5ce7;
  margin-top: 8rpx;
  display: block;
}

.time-picker-wrap {
  /* 只需要用于捕获事件，不需要额外样式 */
  pointer-events: auto !important;
}

/* 修改时间链接的点击反馈 */
.time-picker-wrap .action-link {
  display: inline-block;
  background: rgba(108, 92, 231, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(108, 92, 231, 0.3);
  transition: all 0.2s;
}

.time-picker-wrap .action-link:active {
  background: rgba(108, 92, 231, 0.2);
  transform: scale(0.95);
}

/* History */
.history-card { padding-bottom: 10rpx; }
.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
}
.empty-emoji {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: #8888a0;
}
.record-list { margin-top: 8rpx; }

/* 记录列表滚动容器 */
.records-scroll {
  height: 720rpx;
  margin-top: 8rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  gap: 12rpx;
}
.load-more-text {
  font-size: 24rpx;
  color: #8888a0;
}
.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #2a2a3a;
  border-top-color: #6c5ce7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 1rpx solid #2a2a3a;
}
.record-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.record-date {
  font-size: 24rpx;
  color: #8888a0;
}
.record-weight {
  font-size: 34rpx;
  font-weight: 700;
  color: #e8e8ef;
}
.record-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.record-diff {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
}
.record-diff.down { background: rgba(0, 184, 148, 0.15); color: #00b894; }
.record-diff.up { background: rgba(225, 112, 85, 0.15); color: #e17055; }
.record-diff.neutral { background: rgba(136, 136, 160, 0.1); color: #8888a0; }
.delete-btn {
  font-size: 28rpx;
  color: #8888a0;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
}
.delete-btn:active { color: #e17055; }

/* 编辑图标 */
.edit-icon {
  font-size: 28rpx;
  color: #8888a0;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
}
.edit-icon:active { color: #6c5ce7; }

/* 编辑体重弹窗 */
.edit-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.edit-panel-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.edit-panel {
  position: fixed;
  bottom: -600rpx;
  left: 30rpx;
  right: 30rpx;
  background: #1a1a24;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid #6c5ce7;
  z-index: 1000;
  transition: bottom 0.3s ease;
  margin-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}
.edit-panel.show {
  bottom: 0;
}

.edit-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.edit-panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e8e8ef;
}
.edit-panel-date {
  font-size: 26rpx;
  color: #8888a0;
}
.edit-panel-content {
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.edit-weight-input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #0f0f13;
  border: 1rpx solid #2a2a3a;
  border-radius: 20rpx;
  padding: 0 20rpx;
  color: #e8e8ef;
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}
.edit-weight-input::placeholder {
  color: #8888a0;
  font-weight: 400;
  font-size: 28rpx;
}
.edit-panel-actions {
  display: flex;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}
.btn-cancel {
  flex: 1;
  background: #2a2a3a;
  border: none;
  border-radius: 18rpx;
  color: #8888a0;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 0;
}
.btn-cancel::after { border: none; }
.btn-save {
  flex: 2;
  background: linear-gradient(135deg, #6c5ce7, #5a4bd1);
  border: none;
  border-radius: 18rpx;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 0;
}
.btn-save::after { border: none; }

/* 编辑身高遮罩层 */
.height-edit-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.height-edit-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 编辑身高时，将身高输入组件置于高层级 */
.height-input-wrap {
  z-index: 999;
  position: relative;
}

/* Footer */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 24rpx;
  color: #555570;
}

/* Toast */
.toast {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 100rpx); /* 调整位置，避免被胶囊按钮遮挡 */
  left: 50%;
  transform: translateX(-50%) translateY(-200rpx);
  background: #1a1a24;
  border: 1rpx solid #00b894;
  color: #00b894;
  padding: 20rpx 40rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  z-index: 100;
  transition: transform 0.3s ease;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* 浅色主题加载更多 */
.theme-light .load-more-text {
  color: #868e96;
}
.theme-light .loading-spinner {
  border-color: #dee2e6;
  border-top-color: #6c5ce7;
}
.theme-light .record-item {
  border-top-color: #dee2e6;
}
.theme-light .record-date {
  color: #868e96;
}
.theme-light .record-weight {
  color: #212529;
}

/* ========== 体重编辑弹框样式 ========== */

/* 顶部滑出弹框遮罩 */
.weight-popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 99998;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.weight-popup-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* 顶部滑出弹框 */
.weight-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #1a1a24;
  border-radius: 0 0 32rpx 32rpx;
  z-index: 99999;
  transform: translateY(-600px);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
  margin-top: calc(env(safe-area-inset-top) + 44px);
}

.weight-popup.show {
  transform: translateY(0);
}

.weight-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #2a2a3a;
}

.weight-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e8e8ef;
}

.weight-popup-close {
  font-size: 36rpx;
  color: #8888a0;
  padding: 8rpx 16rpx;
}

.weight-popup-close:active {
  color: #e8e8ef;
}

.weight-popup-body {
  padding: 32rpx;
}

.weight-popup-input-group {
  margin-bottom: 24rpx;
}

.weight-popup-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #e8e8ef;
  display: block;
  margin-bottom: 16rpx;
}

.weight-popup-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weight-popup-input {
  flex: 1;
  background: #0f0f13;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #e8e8ef;
}

.weight-popup-unit {
  font-size: 32rpx;
  color: #8888a0;
  font-weight: 500;
}

.weight-popup-error {
  color: #e17055;
  font-size: 24rpx;
  margin-top: 16rpx;
  text-align: center;
}

.weight-popup-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx 48rpx;
}

.weight-popup-btn-cancel {
  flex: 1;
  padding: 24rpx 0;
  background: #2a2a3a;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #8888a0;
  font-weight: 600;
}

.weight-popup-btn-cancel::after {
  border: none;
}

.weight-popup-btn-cancel:active {
  background: #3a3a4a;
}

.weight-popup-btn-confirm {
  flex: 1;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: white;
  font-weight: 600;
}

.weight-popup-btn-confirm::after {
  border: none;
}

.weight-popup-btn-confirm:active {
  opacity: 0.9;
}

/* 浅色主题弹框 - 弹窗直接在page内，带theme-light类 */
.theme-light.weight-popup {
  background: #ffffff;
}

.theme-light.weight-popup .weight-popup-header {

}
.theme-light .search-results .search-item:active {
  background: #fab00515;
  border-color: #fab005;
}
.theme-light .search-item-name {
  color: #212529;
}
.theme-light .search-item-cal {
  color: #fab005;
}
.theme-light .cal-preview {
  background: #fab00515;
  border-color: #fab00540;
}
.theme-light .cal-preview-label {
  color: #868e96;
}
.theme-light .cal-preview-value {
  color: #fab005;
}
.theme-light .food-tag {
  background: #f8f9fa;
  border-color: #dee2e6;
  color: #212529;
}
.theme-light .food-tag-cal {
  color: #868e96;
}
.theme-light .empty-text {
  color: #212529;
}
.theme-light .empty-hint {
  color: #868e96;
}
.theme-light .title {
  background: linear-gradient(135deg, #fab005, #e67700);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.theme-light .subtitle {
  color: #868e96;
}

/* 浅色主题热量分析卡片 */
.theme-light .calorie-analysis-card {
  background: linear-gradient(135deg, #4c6ef520, #748ffc20);
  border-color: #4c6ef540;
}

.theme-light .calorie-analysis-card:active {
  background: linear-gradient(135deg, #4c6ef530, #748ffc30);
}

.theme-light .analysis-title {
  color: #4c6ef5;
}

.theme-light .analysis-arrow {
  color: #4c6ef5;
}

.theme-light .day-date {
  color: #212529;
}
.theme-light .day-total {
  color: #fab005;
}
.theme-light .meal-type-label {
  color: #212529;
}
.theme-light .meal-cal {
  color: #fab005;
}
.theme-light .remove-food {
  color: #fa5252;
}
.theme-light .quick-item {
  background: #f8f9fa;
  border-color: #dee2e6;
  color: #212529;
}
.theme-light .quick-item:active {
  background: #fab00520;
  border-color: #fab005;
}
.theme-light .close-btn {
  color: #868e96;
}
.theme-light .footer {
  color: #adb5bd;
}
.theme-light .toast {
  background: #ffffff;
  border-color: #40c057;
  color: #40c057;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 浅色主题加载更多 */
.theme-light .load-more-text {
  color: #868e96;
}

.theme-light .loading-spinner {
  border-color: #dee2e6;
  border-top-color: #fab005;
}

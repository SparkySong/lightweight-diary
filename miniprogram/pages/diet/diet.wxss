/* pages/diet/diet.wxss - Vant组件版 */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

.container {
  padding: 30rpx;
  padding-bottom: 100rpx;
  padding-top: calc(env(safe-area-inset-top) + 44px);
  min-height: 100vh;
}

.custom-nav-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 44px);
  background-color: var(--nav-bg, #121212);
  z-index: 9999;
}

.theme-light .custom-nav-area,
page.theme-light {
  --nav-bg: #F8FAF9;
}

.theme-dark .custom-nav-area,
page.theme-dark {
  --nav-bg: #121212;
}

.header {
  padding: 20rpx 0 30rpx;
}

.header-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.subtitle {
  font-size: 24rpx;
}

/* 入口卡片 */
.entry-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.entry-content {
  flex: 1;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
}

.entry-desc {
  font-size: 22rpx;
  display: block;
  margin-top: 4rpx;
}

/* 添加区域 */
.add-section {
  margin: 30rpx 0;
}

/* 添加面板 */
.add-panel {
  margin: 20rpx 0;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
}

/* 餐次选择 */
.meal-types {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  flex-wrap: wrap;
}

/* 食物列表 */
.food-list {
  margin: 16rpx 0;
}

.food-item-row {
  margin-bottom: 16rpx;
}

.food-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cal-unit {
  font-size: 24rpx;
  flex-shrink: 0;
}

.add-food-btn {
  font-size: 26rpx;
  text-align: center;
  padding: 16rpx;
}

/* 搜索面板 */
.food-search-panel {
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 16rpx;
  margin-top: 8rpx;
}

.search-hint {
  font-size: 22rpx;
  margin-bottom: 12rpx;
}

.search-results {
  max-height: 300rpx;
  overflow-y: auto;
}

.search-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 8rpx;
  border-bottom: 1rpx solid var(--divider);
}

.search-item:last-child {
  border-bottom: none;
}

.search-item-name {
  font-size: 26rpx;
}

.search-item-cal {
  font-size: 24rpx;
  font-weight: 500;
}

/* 热量预览 */
.cal-preview {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 16rpx 0;
}

/* 快捷添加 */
.quick-add {
  margin: 16rpx 0;
}

.quick-label {
  font-size: 24rpx;
  display: block;
  margin-bottom: 12rpx;
}

.quick-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 记录列表 */
.records-scroll {
  margin-top: 20rpx;
}

.day-group {
  margin-bottom: 30rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.day-date {
  font-size: 28rpx;
  font-weight: 600;
}

.day-total {
  font-size: 24rpx;
  font-weight: 500;
}

.meal-card {
  margin-bottom: 16rpx;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meal-cal {
  font-size: 26rpx;
  font-weight: 500;
}

.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* 空状态 */
.empty-state {
  margin-top: 100rpx;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 24rpx;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
}

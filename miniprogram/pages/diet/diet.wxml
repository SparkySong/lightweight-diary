<!--pages/diet/diet.wxml-->
<page-meta
  background-text-style="{{currentTheme === 'light' ? 'dark' : 'light'}}"
  background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  background-color-top="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  background-color-bottom="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  root-background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  navigation-bar-style="{{currentTheme === 'light' ? 'dark' : 'light'}}"
/>
<page class="{{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}} {{hidePage ? 'page-hiding' : ''}}">

<view class="theme-bg-fixed {{currentTheme === 'light' ? 'theme-light' : ''}}"></view>
<view class="custom-nav-area"></view>

<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="header-title-row">
      <text class="title mint-text-primary">饮食记录</text>
    </view>
    <text class="subtitle mint-text-secondary">管住嘴，迈开腿</text>
  </view>

  <!-- 热量分析入口卡片 -->
  <view class="mint-card entry-card" bindtap="goToCalorieAnalysis">
    <van-icon name="bar-chart-o" color="var(--color-primary)" size="48rpx" />
    <view class="entry-content">
      <text class="entry-title mint-text-primary">热量分析</text>
      <text class="entry-desc mint-text-tertiary">查看每日热量摄入与达标情况</text>
    </view>
    <van-icon name="arrow" color="var(--text-tertiary)" size="20" />
  </view>

  <!-- 健康问答入口卡片 -->
  <view class="mint-card entry-card mint-mt-md" bindtap="goToAiChat">
    <van-icon name="chat-o" color="var(--color-primary)" size="48rpx" />
    <view class="entry-content">
      <text class="entry-title mint-text-primary">健康问答</text>
      <text class="entry-desc mint-text-tertiary">分析饮食，给出营养建议</text>
    </view>
    <van-icon name="arrow" color="var(--text-tertiary)" size="20" />
  </view>

  <!-- Add Button -->
  <view class="add-section" wx:if="{{!showAddPanel}}">
    <van-button type="primary" block round icon="plus" bindtap="toggleAddPanel">记录饮食</van-button>
  </view>

  <!-- Add/Edit Panel -->
  <view class="mint-card add-panel" wx:if="{{showAddPanel}}">
    <view class="panel-header">
      <text class="panel-title mint-text-primary">{{isEditing ? '编辑饮食' : '添加饮食记录'}}</text>
      <van-icon name="cross" color="var(--text-tertiary)" size="40rpx" bindtap="{{isEditing ? 'cancelEdit' : 'toggleAddPanel'}}" />
    </view>

    <!-- Date -->
    <picker mode="date" value="{{inputDate}}" bindchange="onDateChange">
      <van-cell title="日期" value="{{inputDate || '选择日期'}}" is-link />
    </picker>

    <!-- Meal Type -->
    <view class="meal-types">
      <van-tag
        wx:for="{{mealTypes}}"
        wx:key="key"
        size="large"
        type="{{item.selected ? 'primary' : 'default'}}"
        data-key="{{item.key}}"
        bindtap="selectMealType"
      >{{item.label}}</van-tag>
    </view>

    <!-- Food Items -->
    <view class="food-list" bindtap="hideSearchPanel">
      <block wx:for="{{foods}}" wx:key="index" wx:for-index="foodIdx">
        <view class="food-item-row">
          <view class="food-item">
            <van-field
              placeholder="食物名称"
              value="{{item.name}}"
              data-idx="{{foodIdx}}"
              bind:input="onFoodNameInput"
              bind:focus="onFoodNameInput"
              custom-style="flex: 2;"
            />
            <van-field
              type="digit"
              placeholder="卡路里"
              value="{{item.calories}}"
              data-idx="{{foodIdx}}"
              bind:input="onFoodCalInput"
              custom-style="flex: 1;"
            />
            <text class="cal-unit mint-text-tertiary">kcal</text>
            <van-icon name="minus" color="var(--color-error)" size="40rpx" data-idx="{{foodIdx}}" bindtap="removeFoodItem" />
          </view>
          <!-- 食物搜索建议 -->
          <view class="food-search-panel" wx:if="{{showSearchPanel && searchActiveIndex === foodIdx && searchResults.length > 0}}">
            <view class="search-hint mint-text-secondary">选择以下食物自动填充：</view>
            <view class="search-results">
              <view class="search-item" wx:for="{{searchResults}}" wx:key="name" wx:for-item="result" data-item="{{result}}" data-idx="{{foodIdx}}" catchtap="selectFood">
                <text class="search-item-name mint-text-primary">{{result.name}}</text>
                <text class="search-item-cal mint-text-accent">{{result.calories}} kcal</text>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view class="add-food-btn mint-text-accent" bindtap="addFoodItem">+ 添加更多食物</view>
    </view>

    <!-- 总热量预览 -->
    <view class="cal-preview mint-card-secondary" wx:if="{{showAddPanel}}">
      <text class="mint-text-secondary">本餐预计热量：</text>
      <text class="mint-text-accent" style="font-weight: 600;">{{totalCalPreview}} kcal</text>
    </view>

    <!-- Quick Add -->
    <view class="quick-add">
      <text class="quick-label mint-text-secondary">快捷添加：</text>
      <view class="quick-items">
        <van-tag wx:for="{{quickItems}}" wx:key="name" data-item="{{item}}" bindtap="quickAdd" size="large" plain type="primary">
          {{item.icon}} {{item.name}}
        </van-tag>
      </view>
    </view>

    <van-button type="primary" block round bindtap="onSubmit" style="margin-top: 24rpx;">保存记录</van-button>
  </view>

  <!-- Records by Day -->
  <view wx:if="{{days.length === 0 && !showAddPanel}}" class="empty-state">
    <van-empty description="还没有饮食记录" image="search">
      <van-button round type="primary" size="small" bindtap="toggleAddPanel">开始记录</van-button>
    </van-empty>
  </view>

  <!-- 记录列表 -->
  <scroll-view
    class="records-scroll"
    scroll-y
    enhanced
    disable-scroll
    bindscrolltolower="onScrollToLower"
    lower-threshold="100"
    wx:if="{{days.length > 0}}">
    <view class="day-group" wx:for="{{days}}" wx:key="date" wx:for-item="day">
      <view class="day-header">
        <text class="day-date mint-text-primary">{{day.date}}</text>
        <text class="day-total mint-text-accent">{{day.totalCal}} kcal</text>
      </view>

      <view class="mint-card meal-card" wx:for="{{day.records}}" wx:key="_id" wx:for-item="meal" data-meal="{{meal}}" bindtap="onEditDiet">
        <view class="meal-header">
          <van-tag type="primary" size="medium">{{meal.mealLabel}}</van-tag>
          <view class="meal-actions">
            <text class="meal-cal mint-text-accent">{{meal.totalCal}} kcal</text>
            <van-icon name="edit" color="var(--text-tertiary)" size="36rpx" catchtap="onEditDiet" data-meal="{{meal}}" />
            <van-icon name="delete" color="var(--color-error)" size="36rpx" data-id="{{meal._id}}" catchtap="onDeleteDiet" />
          </view>
        </view>
        <view class="food-tags">
          <van-tag wx:for="{{meal.foods}}" wx:key="name" wx:for-item="food" size="medium" plain>
            {{food.name}} {{food.calories}}cal
          </van-tag>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore || isLoadingMore}}">
      <van-loading wx:if="{{isLoadingMore}}" size="24" />
      <text class="load-more-text mint-text-tertiary" wx:if="{{isLoadingMore}}">加载中...</text>
      <text class="load-more-text mint-text-tertiary" wx:elif="{{!hasMore}}">— 已加载全部 —</text>
    </view>
  </scroll-view>

  <view class="footer">
    <text class="mint-text-tertiary">饮食控制是减肥成功的关键</text>
  </view>
</view>

<van-toast id="van-toast" />
</page>

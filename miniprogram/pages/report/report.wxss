/* pages/report/report.wxss */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

.page-container {
  min-height: 100vh;
  padding: 30rpx 30rpx 60rpx;
  box-sizing: border-box;
  background: #121212;
}

.page-container.theme-light {
  background: #F8FAF9;
}

/* Tab 切换 + 生成按钮 */
.tab-bar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.tab-bar {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 500;
  transition: all 0.2s;
}

.tab-item.tab-active {
  background: rgba(95,168,149,0.15);
  border-color: rgba(95,168,149,0.4);
  color: #22C55E;
  font-weight: 600;
}

.theme-light .tab-item {
  background: rgba(0,0,0,0.03);
  border-color: rgba(0,0,0,0.06);
  color: #6B7280;
}

.theme-light .tab-item.tab-active {
  background: rgba(74,155,138,0.1);
  border-color: rgba(74,155,138,0.3);
  color: #22C55E;
}

.generate-btn {
  padding: 14rpx 28rpx;
  background: rgba(95,168,149,0.15);
  border-radius: 24rpx;
  white-space: nowrap;
}

.generate-btn text {
  font-size: 24rpx;
  color: #22C55E;
  font-weight: 500;
}

.theme-light .generate-btn {
  background: rgba(74,155,138,0.1);
}

.theme-light .generate-btn text {
  color: #22C55E;
}

/* 加载和空状态 */
.loading-box, .empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #4B5563;
}

.loading-text {
  font-size: 28rpx;
  color: #6B7280;
}

/* 报告选择器 */
.report-selector {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.selector-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.selector-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  min-width: 200rpx;
  white-space: normal;
}

.selector-item.selector-active {
  background: rgba(95,168,149,0.12);
  border-color: rgba(95,168,149,0.4);
}

.theme-light .selector-item {
  background: #FFFFFF;
  border-color: rgba(0,0,0,0.06);
}

.theme-light .selector-item.selector-active {
  background: rgba(74,155,138,0.08);
  border-color: rgba(74,155,138,0.3);
}

.selector-date {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.selector-active .selector-date {
  color: #22C55E;
}

.selector-type {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

.selector-active .selector-type {
  color: #22C55E;
  font-weight: 600;
}

/* 报告卡片 */
.report-card {
  background: rgba(30,30,30,0.85);
  border: 1rpx solid rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.15);
}

.theme-light .report-card {
  background: #FFFFFF;
  border-color: rgba(0,0,0,0.06);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.theme-light .report-header {
  border-bottom-color: rgba(0,0,0,0.06);
}

.report-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #22C55E;
}

.theme-light .report-title {
  color: #22C55E;
}

.report-date {
  font-size: 22rpx;
  color: #6B7280;
}

/* 统计数据 */
.report-stats {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.report-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #F5F5F5;
}

.stat-value.stat-green {
  color: #22C55E;
}

.stat-value.stat-red {
  color: #E57373;
}

.theme-light .stat-value {
  color: #1F2937;
}

.theme-light .stat-value.stat-green {
  color: #22C55E;
}

.theme-light .stat-value.stat-red {
  color: #D32F2F;
}

.stat-label {
  font-size: 22rpx;
  color: #6B7280;
}

.report-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.08);
  flex-shrink: 0;
}

.theme-light .report-stat-divider {
  background: rgba(0,0,0,0.06);
}

/* 亮点 */
.report-highlights {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.theme-light .report-highlights {
  border-top-color: rgba(0,0,0,0.06);
}

.highlights-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #F5F5F5;
  margin-bottom: 16rpx;
  display: block;
}

.theme-light .highlights-title {
  color: #1F2937;
}

.highlight-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
}

.highlight-dot {
  font-size: 20rpx;
  color: #22C55E;
  flex-shrink: 0;
}

.theme-light .highlight-dot {
  color: #22C55E;
}

.highlight-text {
  font-size: 26rpx;
  color: #9CA3AF;
  line-height: 1.5;
}

.theme-light .highlight-text {
  color: #6B7280;
}

/* pages/calorie-detail/calorie-detail.wxss */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

/* 安全区域适配 */
.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  min-height: 100vh;
}

/* ========== 标题图标 ========== */
.title-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5FA895;
}

.icon-bowl {
  width: 28rpx;
  height: 22rpx;
  border: 2.5rpx solid currentColor;
  border-radius: 0 0 14rpx 14rpx;
  border-top: none;
  position: relative;
}

.icon-bowl::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 6rpx;
  border: 2.5rpx solid currentColor;
  border-bottom: none;
  border-radius: 10rpx 10rpx 0 0;
}

.icon-settings {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}

.icon-settings::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  background: currentColor;
  border-radius: 50%;
}

.icon-book {
  width: 20rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
}

.icon-book::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 8rpx;
  height: 2rpx;
  background: currentColor;
  box-shadow: 0 5rpx 0 currentColor;
}

.icon-lightbulb {
  width: 18rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 50% 50% 30% 30%;
  position: relative;
}

.icon-lightbulb::before {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 10rpx;
  height: 4rpx;
  border: 2rpx solid currentColor;
  border-top: none;
  border-radius: 0 0 3rpx 3rpx;
}

/* ========== 今日热量总览卡片 ========== */
.overview-card {
  background: var(--card-bg, #1E1E1E);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.overview-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #5FA895, #7BB5AD);
}

.overview-card.danger::before {
  background: linear-gradient(90deg, #C98B8B, #B87B7B);
}

.overview-card.warning::before {
  background: linear-gradient(90deg, #D4A574, #C49A6C);
}

.overview-card.low::before {
  background: linear-gradient(90deg, #8B9EAF, #7A8E9F);
}

.overview-card.success::before {
  background: linear-gradient(90deg, #5FA895, #4A9B8A);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.overview-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
}

.overview-date {
  font-size: 24rpx;
  color: var(--text-secondary, #6B7280);
}

.overview-main {
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 24rpx;
}

.cal-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(95, 168, 149, 0.15), rgba(95, 168, 149, 0.05));
  border: 3rpx solid #5FA895;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cal-circle.danger {
  background: linear-gradient(135deg, rgba(201, 139, 139, 0.15), rgba(201, 139, 139, 0.05));
  border-color: #C98B8B;
}

.cal-circle.warning {
  background: linear-gradient(135deg, rgba(212, 165, 116, 0.15), rgba(212, 165, 116, 0.05));
  border-color: #D4A574;
}

.cal-circle.low {
  background: linear-gradient(135deg, rgba(139, 158, 175, 0.15), rgba(139, 158, 175, 0.05));
  border-color: #8B9EAF;
}

.cal-circle.success {
  background: linear-gradient(135deg, rgba(95, 168, 149, 0.15), rgba(95, 168, 149, 0.05));
  border-color: #5FA895;
}

.cal-current {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary, #F5F5F5);
}

.cal-unit {
  font-size: 22rpx;
  color: var(--text-secondary, #6B7280);
  margin-top: 4rpx;
}

.overview-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stat-label {
  font-size: 26rpx;
  color: var(--text-secondary, #6B7280);
}

.stat-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
}

.stat-value.danger { color: #C98B8B; }
.stat-value.warning { color: #D4A574; }
.stat-value.success { color: #5FA895; }
.stat-value.low { color: #8B9EAF; }

.status-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(95, 168, 149, 0.12);
  border-radius: 30rpx;
  width: fit-content;
  margin: 0 auto;
}

.status-badge.danger {
  background: rgba(201, 139, 139, 0.12);
}

.status-badge.warning {
  background: rgba(212, 165, 116, 0.12);
}

.status-badge.low {
  background: rgba(139, 158, 175, 0.12);
}

.status-badge.success {
  background: rgba(95, 168, 149, 0.12);
}

.status-icon {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #5FA895;
}

.status-icon.danger {
  background: #C98B8B;
}

.status-icon.warning {
  background: #D4A574;
}

.status-icon.low {
  background: #8B9EAF;
}

.status-icon.success {
  background: #5FA895;
}

.status-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #5FA895;
}

.status-text.danger { color: #C98B8B; }
.status-text.warning { color: #D4A574; }
.status-text.low { color: #8B9EAF; }
.status-text.success { color: #5FA895; }

/* ========== 图表卡片 ========== */
.chart-card {
  background: var(--card-bg, #1E1E1E);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
  margin-bottom: 20rpx;
  display: block;
}

/* ========== 饼图布局 ========== */
.pie-detail-container {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.pie-chart-area {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.chart-canvas {
  width: 240rpx;
  height: 240rpx;
}

.pie-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 110rpx;
  background: var(--card-bg, #1E1E1E);
  border-radius: 50%;
}

.pie-center-value {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary, #F5F5F5);
}

.pie-center-label {
  font-size: 20rpx;
  color: var(--text-secondary, #6B7280);
}

/* ========== 饼图右侧图例列表 ========== */
.pie-legend-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pie-legend-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pie-legend-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pie-legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.pie-legend-name {
  font-size: 26rpx;
  color: var(--text-secondary, #6B7280);
  flex: 1;
}

.pie-legend-percent {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary, #F5F5F5);
}

.pie-legend-bar-bg {
  width: 100%;
  height: 8rpx;
  background: var(--bar-bg, #2A2A2A);
  border-radius: 4rpx;
  overflow: hidden;
}

.pie-legend-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.pie-legend-cal {
  font-size: 22rpx;
  color: var(--text-secondary, #6B7280);
}

/* ========== 折线图 ========== */
.line-chart-container {
  width: 100%;
  height: 250rpx;
}

.chart-canvas-line {
  width: 100%;
  height: 250rpx;
}

.chart-hint {
  display: flex;
  gap: 30rpx;
  justify-content: center;
  margin-top: 16rpx;
}

.hint-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary, #6B7280);
}

.hint-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.hint-dot.normal {
  background: #5FA895;
}

.hint-dot.danger {
  background: #C98B8B;
}

.week-summary {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: var(--bg-secondary, #0f0f13);
  border-radius: 12rpx;
  width: fit-content;
  margin-left: auto;
  margin-right: auto;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary, #6B7280);
}

.summary-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
}

.summary-value.danger {
  color: #C98B8B;
}

/* ========== 柱状图 ========== */
.bar-chart-container {
  width: 100%;
  height: 200rpx;
}

.chart-canvas-bar {
  width: 100%;
  height: 200rpx;
}

.meal-recommend {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}

.recommend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.recommend-name {
  font-size: 22rpx;
  color: var(--text-secondary, #6B7280);
}

.recommend-range {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
}

.recommend-range.over {
  color: #C98B8B;
}

/* ========== 智能建议卡片 ========== */
.advice-card {
  background: var(--card-bg, #1E1E1E);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.advice-content {
  margin-top: 16rpx;
}

.advice-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  background: var(--bg-secondary, #0f0f13);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.advice-row.warning {
  background: rgba(212, 165, 116, 0.1);
}

.advice-icon {
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-warning {
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  position: relative;
  color: #D4A574;
}

.icon-warning::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 3rpx;
  height: 6rpx;
  background: currentColor;
  border-radius: 1rpx;
}

.icon-warning::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 3rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 50%;
}

.icon-search {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
  color: #6B7280;
}

.icon-search::after {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 14rpx;
  width: 6rpx;
  height: 2rpx;
  background: currentColor;
  border-radius: 1rpx;
  transform: rotate(45deg);
}

.advice-text {
  font-size: 26rpx;
  color: var(--text-primary, #F5F5F5);
}

.advice-list {
  margin-top: 16rpx;
}

.advice-label {
  font-size: 24rpx;
  color: var(--text-secondary, #6B7280);
  display: block;
  margin-bottom: 12rpx;
}

.advice-item {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.advice-num {
  font-size: 24rpx;
  color: #5FA895;
  font-weight: 600;
  flex-shrink: 0;
}

.advice-desc {
  font-size: 24rpx;
  color: var(--text-primary, #F5F5F5);
  flex: 1;
}

/* ========== 替代推荐 ========== */
.alt-card {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(95, 168, 149, 0.1);
  border: 1rpx solid rgba(95, 168, 149, 0.2);
  border-radius: 12rpx;
}

.alt-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #5FA895;
  display: block;
  margin-bottom: 12rpx;
}

.alt-items {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.alt-item {
  font-size: 22rpx;
  color: var(--text-primary, #F5F5F5);
  padding: 8rpx 16rpx;
  background: var(--bg-secondary, #0f0f13);
  border-radius: 20rpx;
}

/* ========== 鼓励语 ========== */
.encourage {
  margin-top: 16rpx;
  text-align: center;
}

.encourage-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #5FA895;
}

/* ========== 目标设置卡片 ========== */
.target-card {
  background: var(--card-bg, #1E1E1E);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.target-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.target-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.target-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
}

.target-setting {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.target-input-label {
  font-size: 24rpx;
  color: var(--text-secondary, #6B7280);
  flex-shrink: 0;
}

.target-input {
  flex: 1;
  min-width: 120rpx;
  background: var(--bg-secondary, #0f0f13);
  border: 1rpx solid var(--border-color, #2A2A2A);
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 28rpx;
  color: var(--text-primary, #F5F5F5);
}

.btn-save-target {
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, #5FA895, #4A9B8A);
  border: none;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: white;
  font-weight: 600;
}

.btn-save-target::after {
  border: none;
}

.btn-save-target:active {
  opacity: 0.85;
}

.target-current {
  flex: 1;
  font-size: 26rpx;
  color: #5FA895;
  font-weight: 600;
}

.edit-target-btn {
  font-size: 24rpx;
  color: #5FA895;
  padding: 8rpx 16rpx;
  background: rgba(95, 168, 149, 0.12);
  border-radius: 8rpx;
}

.target-hint {
  margin-top: 16rpx;
}

.hint-text-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.hint-text {
  font-size: 22rpx;
  color: var(--text-secondary, #6B7280);
  line-height: 1.5;
}

.tips-icon {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tips-label {
  display: inline-block;
  font-size: 18rpx;
  color: #5FA895;
  background: rgba(95, 168, 149, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* ========== 热量说明卡片 ========== */
.info-card {
  background: var(--card-bg, #1E1E1E);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.info-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary, #F5F5F5);
  display: block;
}

.info-content {
  background: var(--bg-secondary, #0f0f13);
  border-radius: 12rpx;
  padding: 16rpx;
}

.info-text {
  font-size: 24rpx;
  color: var(--text-secondary, #6B7280);
  line-height: 1.8;
}

/* ========== 查看食谱按钮 ========== */
.btn-recipe {
  width: 100%;
  background: linear-gradient(135deg, #5FA895, #4A9B8A);
  border: none;
  border-radius: 50rpx;
  color: white;
  font-size: 30rpx;
  font-weight: 500;
  padding: 22rpx 0;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(95, 168, 149, 0.25);
  transition: all 0.2s ease;
}

.btn-recipe::after {
  border: none;
}

.btn-recipe:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-icon {
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-salad {
  width: 22rpx;
  height: 18rpx;
  border: 2.5rpx solid white;
  border-radius: 0 0 10rpx 10rpx;
  border-top: none;
  position: relative;
}

.icon-salad::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 2rpx;
  width: 4rpx;
  height: 8rpx;
  background: white;
  border-radius: 2rpx 2rpx 0 0;
  box-shadow: 6rpx 0 0 white;
}

/* ========== Footer ========== */
.footer {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--text-tertiary, #4B5563);
}

/* ========== Toast ========== */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  background: var(--card-bg, #1E1E1E);
  border: 1rpx solid #5FA895;
  color: #5FA895;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  z-index: 100000;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
  text-align: center;
  max-width: 80%;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

/* ========== 浅色主题样式 ========== */
.theme-light {
  --card-bg: #FFFFFF;
  --bg-secondary: #F8FAF9;
  --text-primary: #1A1A1A;
  --text-secondary: #6B7280;
  --text-tertiary: #9CA3AF;
  --border-color: #E5E7EB;
  --bar-bg: #F3F4F6;
}

.theme-light .overview-card,
.theme-light .chart-card,
.theme-light .advice-card,
.theme-light .target-card,
.theme-light .info-card {
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.theme-light .cal-circle {
  background: linear-gradient(135deg, rgba(74, 155, 138, 0.1), rgba(74, 155, 138, 0.03));
  border-color: #4A9B8A;
}

.theme-light .cal-circle.danger {
  background: linear-gradient(135deg, rgba(184, 123, 123, 0.1), rgba(184, 123, 123, 0.03));
  border-color: #B87B7B;
}


/* pages/test-inline-theme/test-inline-theme.wxss */
.container {
  padding: 40rpx;
}

.header {
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
}

.test-section {
  margin-bottom: 60rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 32rpx;
}

.theme-info {
  background: var(--bg-card-secondary);
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
}

.info-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.css-var-test {
  margin-bottom: 60rpx;
}

.var-box {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.var-bg-card {
  background: var(--bg-card);
  color: var(--text-primary);
}

.var-bg-page {
  background: var(--bg-page);
  color: var(--text-primary);
}

.var-van-dialog {
  background: var(--van-dialog-background, var(--bg-card));
  color: var(--text-primary);
}

.dialog-form {
  padding: 16rpx 0;
}

.test-text {
  padding: 16rpx 32rpx;
}
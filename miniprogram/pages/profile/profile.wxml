<!--pages/profile/profile.wxml-->
<!-- 页面元信息（必须作为页面第一个节点）-->
<page-meta
  background-text-style="{{currentTheme === 'light' ? 'dark' : 'light'}}"
  background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  background-color-top="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  background-color-bottom="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  root-background-color="{{currentTheme === 'light' ? '#F8FAF9' : '#121212'}}"
  page-style="position: relative;"
/>
<page class="{{currentTheme === 'light' ? 'theme-light' : 'theme-dark'}} {{hidePage ? 'page-hiding' : ''}}">

<!-- 全屏固定背景遮罩层 -->
<view class="theme-bg-fixed {{currentTheme === 'light' ? 'theme-light' : ''}}"></view>

<!-- 自定义导航栏区域 -->
<view class="custom-nav-area"></view>

<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title mint-text-primary">我的</text>
  </view>

  <!-- 个人信息卡片 -->
  <view class="profile-card mint-card">
    <!-- 上半部分：头像 + 昵称 + 箭头 -->
    <view class="profile-top" bindtap="onMenuItemTap" data-action="profile">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" catchtap="stopPropagation">
        <image class="profile-avatar" src="{{avatarUrl}}" mode="aspectFill" />
      </button>
      <view class="profile-info">
        <view class="nickname-row" catchtap="onNicknameTap">
          <text class="profile-nickname mint-text-primary">{{nickname}}</text>
        </view>
        <text class="profile-subtitle mint-text-tertiary">点击管理个人信息</text>
      </view>
      <van-icon name="arrow" color="var(--text-tertiary)" size="20" />
    </view>
    <!-- 下半部分：统计数据 -->
    <view class="profile-stats">
      <view class="profile-stat-item">
        <text class="profile-stat-value mint-text-primary">{{daysCount}}</text>
        <text class="profile-stat-label mint-text-tertiary">打卡天数</text>
      </view>
      <view class="profile-stat-divider"></view>
      <view class="profile-stat-item">
        <text class="profile-stat-value mint-text-primary">{{totalLost}}</text>
        <text class="profile-stat-label mint-text-tertiary">已减({{weightUnit === 'kg' ? 'kg' : '斤'}})</text>
      </view>
      <view class="profile-stat-divider"></view>
      <view class="profile-stat-item">
        <text class="profile-stat-value mint-text-primary">{{goalRemaining}}</text>
        <text class="profile-stat-label mint-text-tertiary">距目标({{weightUnit === 'kg' ? 'kg' : '斤'}})</text>
      </view>
    </view>
  </view>

  <!-- 功能入口列表 -->
  <view class="menu-section">
    <view class="mint-card" style="padding: 0; overflow: hidden;">
      <!-- 个人信息设置 -->
      <van-cell title="个人信息" is-link bindtap="onMenuItemTap" data-action="profile">
        <view slot="right-icon" class="mint-text-tertiary">
          <text wx:if="{{currentWeight}}">{{height}}cm · {{currentWeight}}{{weightUnit === 'kg' ? 'kg' : '斤'}}</text>
          <text wx:elif="{{height}}">{{height}}cm</text>
          <text wx:else>未设置</text>
        </view>
      </van-cell>

      <!-- 每日热量目标 -->
      <van-cell title="热量目标" is-link value="{{calorieGoalDisplay}}" bindtap="onMenuItemTap" data-action="calorieGoal" />

      <!-- 单位与偏好设置 -->
      <van-cell title="偏好设置" is-link value="{{weightUnit === 'kg' ? '千克' : '斤'}}" bindtap="onMenuItemTap" data-action="preferences" />

      <!-- 深色模式设置 -->
      <van-cell title="主题设置" is-link value="{{themeDesc}}" bindtap="onMenuItemTap" data-action="theme" />

      <!-- 健康问答 -->
      <van-cell title="健康问答" is-link value="饮食健康分析" bindtap="onMenuItemTap" data-action="aiChat" />

      <!-- 我的成就 -->
      <van-cell title="我的成就" is-link value="解锁徽章" bindtap="onMenuItemTap" data-action="achievements" />

      <!-- 健康报告 -->
      <van-cell title="健康报告" is-link value="周报月报" bindtap="onMenuItemTap" data-action="report" />

      <!-- 经期记录 -->
      <van-cell title="经期记录" is-link value="私密健康" bindtap="onMenuItemTap" data-action="period" />
    </view>

    <view class="mint-card mint-mt-md" style="padding: 0; overflow: hidden;">
      <!-- 数据管理 -->
      <van-cell title="数据管理" is-link bindtap="onMenuItemTap" data-action="dataManage" />

      <!-- 帮助与反馈 -->
      <van-cell title="帮助与反馈" is-link bindtap="onMenuItemTap" data-action="help" />

      <!-- 关于 -->
      <van-cell title="关于我们" is-link value="v{{version}}" bindtap="onMenuItemTap" data-action="about" />
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-version mint-text-tertiary">轻体日记 v{{version}}</text>
    <view class="footer-links">
      <text class="footer-link mint-text-accent" bindtap="onLinkTap" data-url="agreement">用户协议</text>
      <text class="footer-divider mint-text-tertiary">|</text>
      <text class="footer-link mint-text-accent" bindtap="onLinkTap" data-url="privacy">隐私政策</text>
    </view>
  </view>
</view>

<!-- ========== Vant Dialog 弹窗 ========== -->

<!-- 昵称编辑弹窗 -->
<van-dialog
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  show="{{showNicknameEdit}}"
  title="设置昵称"
  show-cancel-button
  use-slot
  bind:confirm="onSaveNickname"
  bind:cancel="onCloseNicknameEdit"
  bind:close="onCloseNicknameEdit"
>
  <van-field
    type="nickname"
    value="{{editNickname}}"
    bind:input="onEditNicknameInput"
    placeholder="点击获取微信昵称"
    autofocus="{{showNicknameEdit}}"
  />
</van-dialog>

<!-- 个人信息编辑弹窗 -->
<van-dialog
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  show="{{showProfileEdit}}"
  title="编辑个人信息"
  show-cancel-button
  use-slot
  bind:confirm="onSaveProfile"
  bind:cancel="onClosePopup"
  bind:close="onClosePopup"
>
  <view class="dialog-form">
    <van-field label="昵称" value="{{editNickname}}" bind:input="onNicknameInput" placeholder="请输入昵称" maxlength="20" />
    <view class="dialog-form-item">
      <text class="dialog-label">性别</text>
      <view class="gender-options">
        <van-tag size="large" type="{{editGender === 'male' ? 'primary' : 'default'}}" bindtap="onGenderSelect" data-gender="male">👨 男</van-tag>
        <van-tag size="large" type="{{editGender === 'female' ? 'primary' : 'default'}}" bindtap="onGenderSelect" data-gender="female" style="margin-left: 16rpx;">👩 女</van-tag>
      </view>
    </view>
    <van-field label="身高(cm)" type="digit" value="{{editHeight}}" bind:input="onHeightInput" placeholder="请输入身高" />
    <van-field label="当前体重" type="digit" value="{{editCurrentWeight}}" bind:input="onCurrentWeightInput" placeholder="请输入当前体重" />
    <van-field label="目标体重" type="digit" value="{{editGoalWeight}}" bind:input="onGoalWeightInput" placeholder="请输入目标体重" />
  </view>
</van-dialog>

<!-- 热量目标弹窗 -->
<van-dialog
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  show="{{showCalorieGoal}}"
  title="设置每日热量目标"
  show-cancel-button
  use-slot
  bind:confirm="onSaveCalorieGoal"
  bind:cancel="onClosePopup"
  bind:close="onClosePopup"
>
  <view class="dialog-form">
    <van-field label="热量上限" type="number" value="{{editCalorieGoal}}" bind:input="onCalorieGoalInput" placeholder="如 1800" />
    <view class="dialog-tips">
      <text class="mint-text-tertiary" style="font-size: 24rpx;">一般建议：减脂 1200-1500kcal，维持 1500-2000kcal</text>
    </view>
  </view>
</van-dialog>

<!-- 偏好设置弹窗 -->
<van-action-sheet
  show="{{showPreferences}}"
  title="偏好设置"
  bind:close="onClosePopup"
  close-on-click-overlay
>
  <view class="sheet-content">
    <view class="sheet-section">
      <text class="sheet-label mint-text-secondary">体重单位</text>
      <view class="sheet-options">
        <van-tag size="large" type="{{weightUnit === 'kg' ? 'primary' : 'default'}}" bindtap="onWeightUnitChange" data-unit="kg">千克 (kg)</van-tag>
        <van-tag size="large" type="{{weightUnit === 'jin' ? 'primary' : 'default'}}" bindtap="onWeightUnitChange" data-unit="jin" style="margin-left: 16rpx;">斤</van-tag>
      </view>
    </view>
  </view>
</van-action-sheet>

<!-- 主题设置弹窗 -->
<van-action-sheet
  show="{{showThemeSetting}}"
  title="主题设置"
  bind:close="onClosePopup"
  close-on-click-overlay
>
  <view class="sheet-content">
    <van-cell title="跟随系统" bindtap="onSwitchTheme" data-theme="system">
      <van-icon wx:if="{{themeSetting === 'system'}}" name="success" color="var(--color-primary)" slot="right-icon" />
    </van-cell>
    <van-cell title="深色模式" bindtap="onSwitchTheme" data-theme="dark">
      <van-icon wx:if="{{themeSetting === 'dark'}}" name="success" color="var(--color-primary)" slot="right-icon" />
    </van-cell>
    <van-cell title="浅色模式" bindtap="onSwitchTheme" data-theme="light">
      <van-icon wx:if="{{themeSetting === 'light'}}" name="success" color="var(--color-primary)" slot="right-icon" />
    </van-cell>
  </view>
</van-action-sheet>

<!-- 数据管理弹窗 -->
<van-action-sheet
  show="{{showDataManage}}"
  title="数据管理"
  bind:close="onClosePopup"
  close-on-click-overlay
>
  <view class="sheet-content">
    <van-cell title="查看历史记录" is-link bindtap="onViewHistory" />
    <van-cell title="清空所有数据" title-style="color: var(--color-error);" is-link bindtap="onClearAllData" />
  </view>
</van-action-sheet>

<!-- 关于弹窗 -->
<van-dialog
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  show="{{showAbout}}"
  title="关于我们"
  use-slot
  bind:close="onClosePopup"
  confirm-button-text="知道了"
>
  <scroll-view class="about-body" scroll-y enhanced show-scrollbar="{{false}}">
    <image class="about-logo-img" src="/images/qingtilogo.png" mode="widthFix" />
    <text class="about-name mint-text-primary">轻体日记</text>
    <text class="about-version mint-text-tertiary">v{{version}}</text>
    <text class="about-desc mint-text-secondary">一款集体重管理、饮食记录与AI健康助手于一体的智能工具，帮助你坚持记录、科学减脂，遇见更好的自己。</text>
    <view class="about-features">
      <text class="about-feature mint-text-secondary">体重打卡与趋势追踪</text>
      <text class="about-feature mint-text-secondary">饮食记录与热量分析</text>
      <text class="about-feature mint-text-secondary">AI 智能健康问答</text>
      <text class="about-feature mint-text-secondary">BMI 计算与目标管理</text>
      <text class="about-feature mint-text-secondary">运动记录与微信步数同步</text>
      <text class="about-feature mint-text-secondary">深色/浅色主题切换</text>
      <text class="about-feature mint-text-secondary">云端数据同步</text>
    </view>
    <view class="about-contact">
      <text class="mint-text-secondary" style="font-size: 26rpx;">song970502@gmail.com</text>
      <van-button size="small" type="primary" plain bindtap="onCopyEmail" style="margin-top: 16rpx;">复制邮箱</van-button>
    </view>
  </scroll-view>
</van-dialog>

<!-- 帮助弹窗 -->
<van-dialog
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  show="{{showHelp}}"
  title="帮助与反馈"
  use-slot
  bind:close="onClosePopup"
  confirm-button-text="知道了"
>
  <scroll-view class="help-body" scroll-y>
    <view class="help-item">
      <text class="help-q mint-text-primary">如何记录体重？</text>
      <text class="help-a mint-text-secondary">在「打卡」页面，点击当前体重卡片或底部按钮，输入当日体重即可完成打卡。</text>
    </view>
    <view class="help-item">
      <text class="help-q mint-text-primary">如何记录饮食？</text>
      <text class="help-a mint-text-secondary">在「饮食」页面，点击「记录饮食」按钮，选择餐次并输入食物名称和热量即可。</text>
    </view>
    <view class="help-item">
      <text class="help-q mint-text-primary">如何设置目标体重？</text>
      <text class="help-a mint-text-secondary">在「打卡」页面点击目标体重卡片，或在「我的」→「个人信息」中设置。</text>
    </view>
    <view class="help-item">
      <text class="help-q mint-text-primary">数据会丢失吗？</text>
      <text class="help-a mint-text-secondary">数据保存在云端，即使更换设备也能通过同一微信账号恢复。</text>
    </view>
  </scroll-view>
</van-dialog>

<!-- 协议弹窗 -->
<van-dialog
  theme="{{currentTheme === 'light' ? 'light' : 'default'}}"
  show="{{showAgreement}}"
  title="{{agreementTitle}}"
  use-slot
  bind:close="onClosePopup"
  confirm-button-text="知道了"
>
  <scroll-view class="agreement-scroll" scroll-y>
    <text class="mint-text-secondary" style="font-size: 26rpx; line-height: 1.8;">{{agreementContent}}</text>
  </scroll-view>
</van-dialog>

<!-- Toast -->
<van-toast id="van-toast" />

</page>

/* pages/profile/profile.wxss - Vant组件版 */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  padding-top: calc(env(safe-area-inset-top) + 44px);
  min-height: 100vh;
  position: relative;
  width: 100%;
  box-sizing: border-box;
}

.custom-nav-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 44px);
  background-color: var(--nav-bg, #121212);
  z-index: 9999;
}

.theme-light .custom-nav-area,
page.theme-light {
  --nav-bg: #F8FAF9;
}

.theme-dark .custom-nav-area,
page.theme-dark {
  --nav-bg: #121212;
}

.header {
  padding: 20rpx 0 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
}

/* 个人信息卡片 */
.profile-card {
  flex-direction: column;
  margin-bottom: 30rpx;
}

.profile-top {
  display: flex;
  align-items: center;
  padding-bottom: 28rpx;
}

.avatar-btn {
  width: 96rpx;
  height: 96rpx;
  padding: 0;
  margin: 0;
  margin-right: 22rpx;
  border: none;
  background: transparent;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--bg-card-secondary);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.profile-nickname {
  font-size: 34rpx;
  font-weight: 600;
}

.profile-subtitle {
  font-size: 22rpx;
}

/* 统计数据 */
.profile-stats {
  display: flex;
  align-items: center;
  background: var(--bg-card-secondary);
  border-top: 1rpx solid var(--divider);
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}

.profile-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  gap: 6rpx;
}

.profile-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.profile-stat-label {
  font-size: 20rpx;
  white-space: nowrap;
}

.profile-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--divider);
  flex-shrink: 0;
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 30rpx;
}

/* 弹窗表单 */
.dialog-form {
  padding: 20rpx 0;
}

.dialog-form-item {
  padding: 20rpx 32rpx;
}

.dialog-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.gender-options {
  display: flex;
  gap: 16rpx;
}

.dialog-tips {
  padding: 0 32rpx 20rpx;
}

/* Action Sheet 内容 */
.sheet-content {
  padding: 20rpx 0;
}

.sheet-section {
  padding: 20rpx 32rpx;
}

.sheet-label {
  font-size: 26rpx;
  margin-bottom: 16rpx;
  display: block;
}

.sheet-options {
  display: flex;
  gap: 16rpx;
}

/* 关于 */
.about-body {
  max-height: 60vh;
  text-align: center;
  padding: 20rpx 32rpx;
}

.about-logo-img {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  border-radius: 28rpx;
  box-shadow: var(--shadow-md);
}

.about-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.about-version {
  display: block;
  font-size: 26rpx;
  margin-bottom: 28rpx;
}

.about-desc {
  display: block;
  font-size: 25rpx;
  line-height: 1.8;
  margin-bottom: 36rpx;
}

.about-features {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  text-align: left;
  padding-left: 40rpx;
  margin-bottom: 10rpx;
}

.about-feature {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  position: relative;
  padding-left: 24rpx;
}

.about-feature::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 10rpx;
  height: 10rpx;
  background: var(--color-primary);
  border-radius: 50%;
}

.about-contact {
  width: 100%;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--divider);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

/* 帮助 */
.help-body {
  padding: 20rpx 32rpx;
  max-height: 50vh;
}

.help-item {
  margin-bottom: 28rpx;
}

.help-q {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}

.help-a {
  font-size: 24rpx;
  line-height: 1.6;
  display: block;
}

/* 协议 */
.agreement-scroll {
  max-height: 55vh;
  padding: 20rpx 0;
}

/* 底部 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
  gap: 16rpx;
}

.footer-version {
  font-size: 24rpx;
}

.footer-links {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.footer-link {
  font-size: 22rpx;
  font-weight: 500;
}

.footer-divider {
  font-size: 22rpx;
}

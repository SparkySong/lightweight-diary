/* pages/profile/profile.wxss - 现代简约健康App风格 */
@import "/styles/simple-theme.wxss";
@import "/styles/theme.wxss";

.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  padding-top: calc(env(safe-area-inset-top) + 44px);
  min-height: 100vh;
  position: relative;
  width: 100%;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}

.custom-nav-area {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: calc(env(safe-area-inset-top) + 44px);
  background-color: var(--nav-bg, #121212);
  z-index: 9999;
}

/* 浅色主题导航栏 */
.theme-light .custom-nav-area,
page.theme-light {
  --nav-bg: #F8FAF9;
}

.theme-dark .custom-nav-area,
page.theme-dark {
  --nav-bg: #121212;
}

/* Header */
.header {
  padding: 20rpx 0 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #F5F5F5;
  letter-spacing: -0.02em;
}

/* 个人信息卡片 - 优化设计 */
.profile-card {
  display: flex;
  align-items: center;
  background: rgba(30, 30, 30, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.avatar-btn {
  width: 100rpx;
  height: 100rpx;
  padding: 0;
  margin: 0;
  margin-right: 24rpx;
  border: none;
  background: transparent;
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #2D2D2D;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  cursor: pointer;
}

.profile-nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #F5F5F5;
  display: block;
  background: transparent;
  border: none;
  padding: 0;
  text-align: left;
  outline: none;
  -webkit-appearance: none;
}

.profile-nickname::after {
  border: none;
}

.nickname-edit-icon {
  color: #6B7280;
  margin-left: 10rpx;
  width: 22rpx;
  height: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

/* 简化的编辑图标 - 铅笔形状 */
.nickname-edit-icon::before {
  content: '';
  width: 14rpx;
  height: 14rpx;
  border-right: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
  transform: rotate(-45deg);
  position: absolute;
}

.avatar-edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background: #5FA895;
  border-radius: 50%;
  font-size: 18rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #1E1E1E;
}

.nickname-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  text-align: left;
  display: inline;
}

.nickname-btn::after {
  border: none;
}

.profile-stats {
  display: flex;
  align-items: center;
  gap: 0;
}

.profile-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.profile-stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #F5F5F5;
  letter-spacing: -0.02em;
}

.profile-stat-label {
  font-size: 20rpx;
  color: #6B7280;
  margin-top: 6rpx;
  font-weight: 500;
}

.profile-stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.08);
}

.profile-arrow {
  font-size: 32rpx;
  color: #6B7280;
  margin-left: 16rpx;
  flex-shrink: 0;
  font-weight: 300;
}

/* 功能入口列表 */
.menu-section {
  margin-bottom: 30rpx;
}

.menu-card {
  background: rgba(30, 30, 30, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  transition: background-color 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(95, 168, 149, 0.08);
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5FA895;
}

/* 菜单图标 */
.menu-icon-profile::before {
  content: '';
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}

.menu-icon-profile::after {
  content: '';
  position: absolute;
  width: 28rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 10rpx 10rpx 0 0;
  border-bottom: none;
  margin-top: 16rpx;
}

.menu-icon-calorie::before {
  content: '';
  width: 20rpx;
  height: 24rpx;
  border: 2rpx solid currentColor;
  border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
}

.menu-icon-settings::before {
  content: '';
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  position: relative;
}

.menu-icon-settings::after {
  content: '';
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border: 2rpx dashed currentColor;
  border-radius: 50%;
}

.menu-icon-theme::before {
  content: '';
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  box-shadow: inset -6rpx -2rpx 0 0 currentColor;
}

.menu-icon-data::before {
  content: '';
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  position: relative;
}

.menu-icon-data::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: currentColor;
  margin-left: 12rpx;
  margin-top: -12rpx;
}

.menu-icon-help::before {
  content: '?';
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14rpx;
  font-weight: 600;
}

.menu-icon-about::before {
  content: 'i';
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14rpx;
  font-weight: 600;
  font-style: italic;
}

.menu-text {
  font-size: 30rpx;
  color: #F5F5F5;
  font-weight: 500;
}

.menu-item-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

.menu-arrow {
  font-size: 28rpx;
  color: #6B7280;
  font-weight: 300;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 20rpx;
  gap: 16rpx;
}

.footer-version {
  font-size: 24rpx;
  color: #4B5563;
}

.footer-links {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.footer-link {
  font-size: 22rpx;
  color: #5FA895;
  font-weight: 500;
}

.footer-divider {
  font-size: 22rpx;
  color: #4B5563;
}

/* ========== 弹窗通用样式 ========== */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.popup-panel {
  width: 100%;
  background: #1E1E1E;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  animation: slideUp 0.3s ease;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.nickname-popup {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.popup-panel-large {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.popup-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 32rpx;
  color: #6B7280;
  transition: all 0.2s;
}

.popup-close:active {
  background: rgba(255, 255, 255, 0.08);
  color: #9CA3AF;
}

.popup-body {
  margin-bottom: 30rpx;
}

.popup-footer {
  display: flex;
  gap: 20rpx;
}

.popup-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  border: none;
  padding: 0;
  margin: 0;
  font-weight: 500;
  transition: all 0.2s;
}

.popup-btn::after {
  border: none;
}

.popup-btn:active {
  opacity: 0.85;
}

.popup-btn-cancel {
  background: #3D3D3D;
  color: #9CA3AF;
}

.popup-btn-confirm {
  background: #5FA895;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(95, 168, 149, 0.25);
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #2D2D2D;
  border: 1rpx solid #3D3D3D;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #F5F5F5;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #6B7280;
}

.form-tips {
  margin-top: 16rpx;
}

.form-tip {
  font-size: 22rpx;
  color: #6B7280;
}

/* 设置选项 */
.setting-group {
  margin-bottom: 36rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.setting-options {
  display: flex;
  gap: 16rpx;
}

.setting-option {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2D2D2D;
  border: 2rpx solid #3D3D3D;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #F5F5F5;
  font-weight: 500;
  transition: all 0.2s;
}

.setting-option.active {
  background: rgba(95, 168, 149, 0.12);
  border-color: #5FA895;
  color: #5FA895;
}

/* 主题选项 */
.theme-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.theme-option {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #2D2D2D;
  border: 2rpx solid #3D3D3D;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.theme-option.active {
  background: rgba(95, 168, 149, 0.12);
  border-color: #5FA895;
}

.theme-option-img {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.theme-option.active .theme-option-img {
  opacity: 1;
}

.theme-option-text {
  flex: 1;
  font-size: 30rpx;
  color: #F5F5F5;
  font-weight: 500;
}

.theme-option-check {
  font-size: 30rpx;
  color: #5FA895;
  font-weight: 600;
}

/* 数据管理 */
.data-manage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.data-manage-item:last-child {
  border-bottom: none;
}

.data-manage-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.data-manage-icon {
  font-size: 36rpx;
}

.data-manage-text {
  font-size: 30rpx;
  color: #F5F5F5;
  font-weight: 500;
}

.data-manage-danger .data-manage-text {
  color: #C98B8B;
}

/* 关于 */
.about-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 20rpx 0;
}

.about-logo {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #5FA895, #6B8E9F);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(95, 168, 149, 0.25);
}

.about-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #F5F5F5;
  margin-bottom: 8rpx;
  letter-spacing: -0.02em;
}

.about-version {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.about-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 30rpx;
  padding: 0 20rpx;
}

.about-features {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
  align-items: flex-start;
  padding-left: 40rpx;
}

.about-feature {
  font-size: 26rpx;
  color: #F5F5F5;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-weight: 500;
}

.about-feature::before {
  content: '';
  width: 8rpx;
  height: 8rpx;
  background: #5FA895;
  border-radius: 50%;
}

/* 帮助 */
.help-body {
  padding: 0;
}

.help-item {
  margin-bottom: 28rpx;
}

.help-q {
  font-size: 28rpx;
  font-weight: 600;
  color: #F5F5F5;
  display: block;
  margin-bottom: 10rpx;
}

.help-a {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  display: block;
}

.help-feedback {
  margin-top: 30rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.help-feedback-text {
  font-size: 24rpx;
  color: #6B7280;
}

.help-feedback-btn {
  width: 300rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: #5FA895;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 38rpx;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(95, 168, 149, 0.25);
}

.help-feedback-btn::after {
  border: none;
}

.help-feedback-btn:active {
  opacity: 0.85;
}

/* 协议 */
.agreement-body {
  padding: 0;
  max-height: 55vh;
  overflow: hidden;
}

.agreement-scroll {
  max-height: 55vh;
}

.agreement-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(30, 30, 30, 0.95);
  color: #F5F5F5;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  z-index: 99999;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.toast-show {
  opacity: 1;
}

.toast-text {
  color: #F5F5F5;
}

/* ========== 浅色主题 ========== */
.container.theme-light .profile-card {
  background: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.container.theme-light .profile-avatar {
  /* 移除边框 */
}

.container.theme-light .profile-nickname {
  color: #1F2937;
}

.container.theme-light .nickname-edit-icon {
  color: #9CA3AF;
}

.container.theme-light .profile-stat-value {
  color: #1F2937;
}

.container.theme-light .profile-stat-label {
  color: #6B7280;
}

.container.theme-light .profile-stat-divider {
  background: rgba(0, 0, 0, 0.06);
}

.container.theme-light .profile-arrow {
  color: #9CA3AF;
}

.container.theme-light .menu-card {
  background: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.container.theme-light .menu-item {
  border-bottom-color: rgba(0, 0, 0, 0.06);
}

.container.theme-light .menu-item:active {
  background: rgba(74, 155, 138, 0.06);
}

.container.theme-light .menu-text {
  color: #1F2937;
}

.container.theme-light .menu-desc {
  color: #6B7280;
}

.container.theme-light .menu-arrow {
  color: #9CA3AF;
}

.container.theme-light .footer-version {
  color: #9CA3AF;
}

.container.theme-light .footer-link {
  color: #4A9B8A;
}

.container.theme-light .footer-divider {
  color: #D1D5DB;
}

/* 浅色主题弹窗 */
page.theme-light .popup-panel {
  background: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.08);
}

page.theme-light .popup-overlay {
  background: rgba(0, 0, 0, 0.4);
}

page.theme-light .popup-title {
  color: #1F2937;
}

page.theme-light .popup-close {
  color: #9CA3AF;
}

page.theme-light .popup-close:active {
  background: rgba(0, 0, 0, 0.06);
  color: #6B7280;
}

page.theme-light .popup-btn-cancel {
  background: #E5E7EB;
  color: #6B7280;
}

page.theme-light .popup-btn-cancel:active {
  background: #D1D5DB;
}

page.theme-light .popup-btn-confirm {
  background: #4A9B8A;
  box-shadow: 0 4rpx 16rpx rgba(74, 155, 138, 0.2);
}

page.theme-light .form-input {
  background: #F0F4F3;
  border-color: #E5E7EB;
  color: #1F2937;
}

page.theme-light .form-input::placeholder {
  color: #9CA3AF;
}

page.theme-light .form-tip {
  color: #6B7280;
}

page.theme-light .form-label {
  color: #6B7280;
}

page.theme-light .setting-label {
  color: #6B7280;
}

page.theme-light .setting-option {
  background: #F0F4F3;
  border-color: #E5E7EB;
  color: #1F2937;
}

page.theme-light .setting-option.active {
  background: rgba(74, 155, 138, 0.1);
  border-color: #4A9B8A;
  color: #4A9B8A;
}

page.theme-light .theme-option {
  background: #F0F4F3;
  border-color: #E5E7EB;
}

page.theme-light .theme-option.active {
  background: rgba(74, 155, 138, 0.1);
  border-color: #4A9B8A;
}

page.theme-light .theme-option-text {
  color: #1F2937;
}

page.theme-light .theme-option-check {
  color: #4A9B8A;
}

page.theme-light .data-manage-item {
  border-bottom-color: rgba(0, 0, 0, 0.06);
}

page.theme-light .data-manage-text {
  color: #1F2937;
}

page.theme-light .data-manage-danger .data-manage-text {
  color: #B87B7B;
}

page.theme-light .about-name {
  color: #1F2937;
}

page.theme-light .about-version {
  color: #6B7280;
}

page.theme-light .about-desc {
  color: #6B7280;
}


/* app.wxss - 全局样式 */
@import './styles/design-system.wxss';
page {
  color: #F5F5F5;
  /* 默认深色背景，避免tab切换时第一帧出现白色闪烁 */
  background-color: #121212;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  /* 关键：平滑过渡主题切换，掩盖框架底色闪烁 */
  transition: background-color 0.25s ease, color 0.25s ease;
}

/* 浅色主题下的字体颜色调整 */
page.theme-light {
  color: #1F2937;
  background-color: #F8FAF9;
}

/* 全屏固定背景遮罩层：覆盖 app.json window.backgroundColor 的默认底色，
   防止 tab 切换时第一帧出现与当前主题不一致的背景色 */
.theme-bg-fixed {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  background-color: #121212;
  transition: background-color 0.25s ease;
  pointer-events: none;
}
.theme-bg-fixed.theme-light {
  background-color: #F8FAF9;
}

/* 防闪炃：主题切换后第一次切 tab 时，短暂隐藏页面内容，
   等 DOM 渲染新主题完成后再显示，避免看到旧主题的残留帧。
   期间用户看到的是 .theme-bg-fixed 遮罩层的新主题色。 */
.page-hiding {
  visibility: hidden;
}
/* 需要在 page 隐藏期间仍然显示 theme-bg-fixed 遮罩（新主题底色） */
.page-hiding .theme-bg-fixed {
  visibility: visible;
}

/* 全局字体层级 */
.text-display {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.text-headline {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.3;
}

.text-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.text-body {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.5;
}

.text-caption {
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.4;
}

.text-small {
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.4;
}

/* 通用卡片样式 */
.card-base {
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  transition: all 0.3s ease;
}

/* 胶囊按钮 */
.btn-capsule {
  border-radius: 50rpx;
  padding: 16rpx 40rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.btn-capsule:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 线性图标样式 */
.icon-linear {
  stroke-width: 2;
  fill: none;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* 主题样式变量定义 - 现代简约健康App风格 */

/* 深色主题（默认）- 使用深灰替代纯黑，低饱和度配色 */
:root {
  /* 基础颜色 - 深色模式 */
  --color-bg-primary: #121212;        /* 主背景：深灰替代纯黑 */
  --color-bg-secondary: #1E1E1E;      /* 卡片背景 */
  --color-bg-tertiary: #2D2D2D;       /* 输入框背景 */
  --color-text-primary: #F5F5F5;      /* 主文字：柔和白 */
  --color-text-secondary: #9CA3AF;    /* 次要文字：柔和灰 */
  --color-text-tertiary: #6B7280;     /* 辅助文字 */
  
  /* 品牌主色 - 清新薄荷绿 */
  --color-accent-primary: #22C55E;    /* 主色调：薄荷绿 */
  --color-accent-secondary: #4ADE80;  /* 辅助色：浅薄荷绿 */
  --color-accent-tertiary: #16A34A;   /* 第三色：深薄荷绿 */
  
  --color-border: #2D2D2D;            /* 边框色 */
  
  /* 组件相关 */
  --color-stat-card-bg: rgba(30, 30, 30, 0.85);
  --color-chart-bg: #1E1E1E;
  --color-input-bg: #2D2D2D;
  --color-input-border: #3D3D3D;
  --color-button-primary: #22C55E;
  --color-button-secondary: #2D2D2D;
  
  /* 状态颜色 - 低饱和度 */
  --color-success: #22C55E;           /* 薄荷绿 */
  --color-warning: #D4A574;           /* 暖橙色替代高饱和 */
  --color-danger: #C98B8B;            /* 柔和红 */
  --color-info: #8B9DC3;              /* 淡紫色 */
  
  /* BMI 颜色 - 低饱和度 */
  --color-bmi-bg: #4B5563;
  --color-bmi-underweight: #6B7280;
  --color-bmi-healthy: #22C55E;
  --color-bmi-overweight: #D4A574;
  --color-bmi-obese: #C98B8B;
  
  /* 导航栏 */
  --color-nav-bg: #121212;
  --color-tab-bar-bg: #121212;
  --color-tab-icon: #6B7280;
  --color-tab-icon-active: #22C55E;
  
  /* 趋势图颜色 */
  --color-trend-line: #22C55E;
  --color-trend-fill: rgba(34, 197, 94, 0.1);
  --color-grid-line: rgba(156, 163, 175, 0.15);
}

/* 浅色主题 */
[data-theme="light"] {
  /* 基础颜色 - 浅色模式 */
  --color-bg-primary: #F8FAF9;        /* 主背景：极淡薄荷灰 */
  --color-bg-secondary: #FFFFFF;      /* 卡片背景 */
  --color-bg-tertiary: #F0F4F3;       /* 输入框背景 */
  --color-text-primary: #1F2937;      /* 主文字 */
  --color-text-secondary: #6B7280;    /* 次要文字 */
  --color-text-tertiary: #9CA3AF;     /* 辅助文字 */
  
  /* 品牌主色 - 清新薄荷绿 */
  --color-accent-primary: #22C55E;    /* 主色调：薄荷绿 */
  --color-accent-secondary: #4ADE80;  /* 辅助色：浅薄荷绿 */
  --color-accent-tertiary: #16A34A;   /* 第三色 */
  
  --color-border: #E5E7EB;            /* 边框色 */
  
  /* 组件相关 */
  --color-stat-card-bg: #FFFFFF;
  --color-chart-bg: #FFFFFF;
  --color-input-bg: #F0F4F3;
  --color-input-border: #E5E7EB;
  --color-button-primary: #22C55E;
  --color-button-secondary: #FFFFFF;
  
  /* 状态颜色 */
  --color-success: #22C55E;
  --color-warning: #C49A6C;
  --color-danger: #B87B7B;
  --color-info: #7A8FB8;
  
  /* BMI 颜色 */
  --color-bmi-bg: #D1D5DB;
  --color-bmi-underweight: #9CA3AF;
  --color-bmi-healthy: #22C55E;
  --color-bmi-overweight: #C49A6C;
  --color-bmi-obese: #B87B7B;
  
  /* 导航栏 */
  --color-nav-bg: #F8FAF9;
  --color-tab-bar-bg: #F8FAF9;
  --color-tab-icon: #9CA3AF;
  --color-tab-icon-active: #22C55E;
  
  /* 趋势图颜色 */
  --color-trend-line: #22C55E;
  --color-trend-fill: rgba(34, 197, 94, 0.1);
  --color-grid-line: rgba(156, 163, 175, 0.2);
}

/* 应用主题样式到组件 */
.stat-card {
  background-color: var(--color-stat-card-bg);
  border-color: var(--color-border);
}

.card {
  background-color: var(--color-stat-card-bg);
  border-color: var(--color-border);
}

.btn-primary {
  background-color: var(--color-button-primary);
  color: white;
}

.btn-secondary {
  background-color: var(--color-button-secondary);
  border-color: var(--color-border);
  color: var(--color-text-primary);
}

.stat-label, .card-title {
  color: var(--color-text-secondary);
}

.stat-value {
  color: var(--color-text-primary);
}

.title {
  color: var(--color-text-primary);
}

.subtitle {
  color: var(--color-text-secondary);
}

/* 页面背景 */
page {
  background-color: var(--color-bg-primary);
}

/* 容器背景 */
.container {
  background-color: var(--color-bg-primary);
}

/* 自定义导航栏 */
.custom-nav-area {
  background-color: var(--color-nav-bg);
}

/* 输入框 */
input, .input, .btn {
  background-color: var(--color-input-bg);
  border-color: var(--color-input-border);
  color: var(--color-text-primary);
}

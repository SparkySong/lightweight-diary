/* 简易主题切换CSS - 现代简约健康App风格 */

/* 全局CSS变量定义 */
:root {
  --page-bg-dark: #121212;
  --page-bg-light: #F8FAF9;
  --nav-bg-dark: #121212;
  --nav-bg-light: #F8FAF9;
  --content-bg-dark: #121212;
  --content-bg-light: #F8FAF9;
  
  /* 品牌色 */
  --brand-primary-dark: #5FA895;
  --brand-primary-light: #4A9B8A;
  --brand-secondary-dark: #6B8E9F;
  --brand-secondary-light: #5A7D8C;
}

/* 深色主题（默认） */
page.theme-dark {
  background-color: var(--page-bg-dark, #121212);
  transition: background-color 0.25s ease, color 0.25s ease;
}

/* 确保深色主题的下拉区域也是深色 */
page.theme-dark .page__background {
  background-color: #121212;
}

page.theme-dark .wx-pull-to-refresh__area {
  background-color: #121212;
}

page.theme-dark .page__bd {
  background-color: #121212;
}

/* 浅色主题 */
page.theme-light {
  background-color: var(--page-bg-light, #F8FAF9);
  transition: background-color 0.25s ease, color 0.25s ease;
}

/* 确保浅色主题的下拉区域也是浅色 */
page.theme-light .page__background {
  background-color: #F8FAF9;
}

page.theme-light .wx-pull-to-refresh__area {
  background-color: #F8FAF9;
}

page.theme-light .page__bd {
  background-color: #F8FAF9;
}

.container.theme-dark {
  background-color: var(--content-bg-dark, #121212);
  min-height: 100vh;
  transition: background-color 0.25s ease;
}

.container.theme-light {
  background-color: var(--content-bg-light, #F8FAF9);
  min-height: 100vh;
  transition: background-color 0.25s ease;
}

/* 卡片样式 - 深色主题 */
.container.theme-dark .stat-card,
.container.theme-dark .card {
  background-color: rgba(30, 30, 30, 0.85);
  border-color: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.container.theme-dark .stat-label,
.container.theme-dark .card-title {
  color: #9CA3AF;
}

.container.theme-dark .stat-value {
  color: #F5F5F5;
}

.container.theme-dark .title {
  color: #F5F5F5;
}

.container.theme-dark .subtitle {
  color: #9CA3AF;
}

/* 卡片样式 - 浅色主题 */
.container.theme-light .stat-card,
.container.theme-light .card {
  background-color: #FFFFFF;
  border-color: rgba(0, 0, 0, 0.06);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.container.theme-light .stat-label,
.container.theme-light .card-title {
  color: #6B7280;
}

.container.theme-light .stat-value {
  color: #1F2937;
}

.container.theme-light .title {
  color: #1F2937;
}

.container.theme-light .subtitle {
  color: #6B7280;
}

/* 顶部安全区域 - 深色主题毛玻璃效果 */
.container.theme-dark .custom-nav-area,
page.theme-dark .custom-nav-area {
  background: linear-gradient(180deg, rgba(18, 18, 18, 0.98) 0%, rgba(18, 18, 18, 0.95) 100%);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
}

/* 顶部安全区域 - 浅色主题毛玻璃效果 */
.container.theme-light .custom-nav-area,
page.theme-light .custom-nav-area {
  background: linear-gradient(180deg, rgba(248, 250, 249, 0.98) 0%, rgba(248, 250, 249, 0.95) 100%);
  backdrop-filter: saturate(180%) blur(20rpx);
  -webkit-backdrop-filter: saturate(180%) blur(20rpx);
}

/* 按钮样式 - 深色主题 */
.container.theme-dark .btn-primary {
  background: #5FA895;
  color: white;
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(95, 168, 149, 0.25);
}

.container.theme-dark .btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.container.theme-dark .btn-secondary {
  background: #2D2D2D;
  color: #F5F5F5;
  border-color: #3D3D3D;
}

/* 按钮样式 - 浅色主题 */
.container.theme-light .btn-primary {
  background: #4A9B8A;
  color: white;
  border-radius: 50rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(74, 155, 138, 0.2);
}

.container.theme-light .btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.container.theme-light .btn-secondary {
  background: #FFFFFF;
  color: #1F2937;
  border-color: #E5E7EB;
}

/* BMI相关 - 深色主题 */
.container.theme-dark .bmi-bar-bg {
  background: #4B5563;
}

.container.theme-dark .bmi-text,
.container.theme-dark .bmi-category {
  color: #F5F5F5;
}

/* BMI相关 - 浅色主题 */
.container.theme-light .bmi-bar-bg {
  background: #D1D5DB;
}

.container.theme-light .bmi-text,
.container.theme-light .bmi-category {
  color: #1F2937;
}

/* 输入框 - 深色主题 */
.container.theme-dark input,
.container.theme-dark .input,
.container.theme-dark .height-input,
.container.theme-dark .weight-input {
  background: #2D2D2D;
  border-color: #3D3D3D;
  color: #F5F5F5;
  border-radius: 12rpx;
}

/* 深色模式 - 打卡输入框容器 */
.container.theme-dark .weight-input-wrap {
  background: #2D2D2D;
  border-color: #3D3D3D;
  border-radius: 12rpx;
}

.container.theme-dark .weight-placeholder {
  color: #6B7280;
}

.container.theme-dark .weight-input {
  color: #F5F5F5;
}

/* 输入框 - 浅色主题 */
.container.theme-light input,
.container.theme-light .input,
.container.theme-light .height-input,
.container.theme-light .weight-input {
  background: #F0F4F3;
  border-color: #E5E7EB;
  color: #1F2937;
  border-radius: 12rpx;
}

/* 浅色模式 - 打卡输入框容器 */
.container.theme-light .weight-input-wrap {
  background: #F0F4F3;
  border-color: #E5E7EB;
  border-radius: 12rpx;
}

.container.theme-light .weight-placeholder {
  color: #9CA3AF;
}

.container.theme-light .weight-input {
  color: #1F2937;
}

/* 浅色模式下输入框 placeholder */
.container.theme-light input::placeholder,
.container.theme-light .input::placeholder,
.container.theme-light .height-input::placeholder,
.container.theme-light .weight-input::placeholder {
  color: #9CA3AF;
}

/* 深色模式下输入框 placeholder */
.container.theme-dark input::placeholder,
.container.theme-dark .input::placeholder,
.container.theme-dark .height-input::placeholder,
.container.theme-dark .weight-input::placeholder {
  color: #6B7280;
}

/* 状态颜色 - 深色主题 */
.container.theme-dark .down { color: #5FA895; }
.container.theme-dark .up { color: #C98B8B; }
.container.theme-dark .neutral { color: #9CA3AF; }

/* 状态颜色 - 浅色主题 */
.container.theme-light .down { color: #4A9B8A; }
.container.theme-light .up { color: #B87B7B; }
.container.theme-light .neutral { color: #6B7280; }

/* 趋势图网格线 */
.container.theme-dark .chart-grid {
  stroke: rgba(156, 163, 175, 0.15);
  stroke-dasharray: 4, 4;
}

.container.theme-light .chart-grid {
  stroke: rgba(156, 163, 175, 0.2);
  stroke-dasharray: 4, 4;
}
